<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.KSuiteUpgradeBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">

    <Border CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
            BorderThickness="1"
            Height="58">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,0">
                <GradientStop Color="{ThemeResource Infomaniak.DS.kSuite.Gradient.lightblue}"
                              Offset="0.0" />
                <GradientStop Color="{ThemeResource Infomaniak.DS.kSuite.Gradient.darkblue}"
                              Offset="0.25" />
                <GradientStop Color="{ThemeResource Infomaniak.DS.kSuite.Gradient.purple}"
                              Offset="0.5" />
                <GradientStop Color="{ThemeResource Infomaniak.DS.kSuite.Gradient.pink}"
                              Offset="0.75" />
                <GradientStop Color="{ThemeResource Infomaniak.DS.kSuite.Gradient.orange}"
                              Offset="1.0" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <SolidColorBrush Color="{ThemeResource LayerFillColorDefault}" />
        </Border.Background>

        <Grid VerticalAlignment="Center"
              Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.M}"
              ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <!-- kSuite icon / message -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Left"
                        Grid.Column="0"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                        Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.M}">
                <controls:SvgIcon HorizontalAlignment="Left"
                                  Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                  UriString="{ThemeResource Infomaniak.Custom.Icons.logo-myksuiteplus}" />
                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('myksuitePlusBannerDescription')}"
                           HorizontalAlignment="Left"
                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
            </StackPanel>

            <HyperlinkButton x:Name="UpgradeHyperLinkButton"
                             Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonUpgradeOffer')}"
                             HorizontalAlignment="Right"
                             HorizontalContentAlignment="Right"
                             Grid.Column="1" />
        </Grid>
    </Border>
</UserControl>
