<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.SyncIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>

    <Viewbox>
        <controls:SvgIcon Height="{x:Bind Height, Mode=OneWay}"
                          Width="{x:Bind Width, Mode=OneWay}"
                          UriString="{x:Bind IconUri, Mode=OneWay}"
                          Foreground="{x:Bind Sync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}" />
    </Viewbox>
</UserControl>
