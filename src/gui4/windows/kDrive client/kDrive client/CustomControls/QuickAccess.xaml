<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.QuickAccess"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>
    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.M}">
        <Grid MinWidth="0">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.L}">
                <Canvas HorizontalAlignment="Center"
                        Width="46"
                        Height="46">

                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="1.1"
                            CornerRadius="100"
                            Canvas.ZIndex="0"
                            Canvas.Left="0"
                            Canvas.Top="0">
                        <PersonPicture ProfilePicture="{x:Bind ViewModel.SelectedSync.Drive.Account.User.GetAvatarImageSource(44), Mode=OneWay}"
                                       Height="44"
                                       Width="44">
                        </PersonPicture>
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Account.User.Name, Mode=OneWay}"
                                     Placement="Right" />
                        </ToolTipService.ToolTip>
                    </Border>
                    <Border Canvas.ZIndex="2"
                            Canvas.Left="30"
                            Canvas.Top="30"
                            Height="20"
                            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                            CornerRadius="100"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XXS}">
                        <Viewbox>
                            <controls:SvgIcon Height="12"
                                              Width="12"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                              Foreground="{x:Bind ViewModel.SelectedSync.Drive.Color, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" />
                        </Viewbox>
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Name, Mode=OneWay}"
                                     Placement="Right" />
                        </ToolTipService.ToolTip>
                    </Border>

                </Canvas>
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="FavoritesButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Actions.star}"
                                                  Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderFavorites')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>
                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="SharedButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-share}"
                                                  Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderShares')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="OpenDriveOnlineButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive-outline}"
                                                  Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('buttonKDriveOnline')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Click="TrashButton_Click">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon Height="13"
                                          Width="13"
                                          UriString="{StaticResource Infomaniak.DS.Icons.Actions.trashbin}"
                                          Foreground="{ThemeResource SystemAccentColor}" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderTrash')}"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                    </StackPanel>
                    <controls:SvgIcon Height="10"
                                      Width="10"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                </Grid>
            </Button>

        </Grid>
    </Border>

</UserControl>
