<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.QuickAccess"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>
    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.M}">
        <Grid MinWidth="180">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.L}">
                <Canvas HorizontalAlignment="Center"
                        Width="46"
                        Height="46">

                    <Border BorderBrush="{StaticResource Infomaniak.Style.Color.Brand.Default}"
                            BorderThickness="2"
                            CornerRadius="100"
                            Canvas.ZIndex="0"
                            Canvas.Left="0"
                            Canvas.Top="0">
                        <PersonPicture ProfilePicture="{x:Bind ViewModel.SelectedSync.Drive.Account.User.AvatarImageSource, Mode=OneWay}"
                                       Height="41"
                                       Width="41">
                        </PersonPicture>
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Account.User.Name, Mode=OneWay}" Placement="Right"/>
                        </ToolTipService.ToolTip>
                    </Border>
                    <Border Canvas.ZIndex="2"
                            Canvas.Left="30"
                            Canvas.Top="30"
                            Height="20"
                            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                            CornerRadius="100"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XXS}">
                        <Viewbox>
                            <controls:SvgIcon Height="16"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                              Foreground="{x:Bind ViewModel.SelectedSync.Drive.Color, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" />
                        </Viewbox>
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Name, Mode=OneWay}" Placement="Right"/>
                        </ToolTipService.ToolTip>
                    </Border>

                </Canvas>
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="FavoritesButton_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="12"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  UriString="{StaticResource Infomaniak.Custom.Icons.folder-star}" />
                                <TextBlock x:Uid="CC_QuickAccess_favorites"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>
                            <controls:SvgIcon Height="12"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="SharedButton_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="16"
                                                  UriString="{StaticResource Infomaniak.Custom.Icons.folder-share}" />
                                <TextBlock x:Uid="CC_QuickAccess_shared"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Height="12"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="OpenDriveOnlineButton_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="16"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                                  Foreground="#446FDD" />
                                <!--TODO: Color to be updated once DS completed-->
                                <TextBlock x:Uid="CC_QuickAccess_onlineDrive"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Height="12"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Click="TrashButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Dashed border -->
                            <Rectangle Stroke="{StaticResource Infomaniak.Style.Color.Product.Default}"
                                       StrokeThickness="1"
                                       RadiusX="3"
                                       RadiusY="3"
                                       StrokeDashArray="3,3"
                                       Fill="Transparent" />

                            <!-- Your content -->
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Grid>
                    </ControlTemplate>
                </Button.Template>

                <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                      HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon Height="16"
                                          UriString="{StaticResource Infomaniak.DS.Icons.Actions.trashbin}"
                                          Foreground="#5C89F7"/>

                        <TextBlock x:Uid="CC_QuickAccess_trash"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                    </StackPanel>
                </Grid>
            </Button>

        </Grid>
    </Border>

</UserControl>
