<UserControl x:Class="Infomaniak.kDrive.CustomControls.QuickAccess"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}"
            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.M}">
        <Grid>
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.L}">
                <Canvas HorizontalAlignment="Center"
                        Width="46"
                        Height="46">
                    <!-- Person Picture Button -->
                    <Border CornerRadius="100"
                            Canvas.ZIndex="0"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                            BorderThickness="1.2">

                        <Button x:Name="PersonPictureButton"
                            Padding="0"
                            Margin="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ProfilePictureBorder_Click"
                            AutomationProperties.Name="{x:Bind ViewModel.SelectedSync.Drive.Account.User.Name, Mode=OneWay}"
                            PointerEntered="PersonPictureButton_PointerEntered"
                            PointerExited="PersonPictureButton_PointerExited">
                            <PersonPicture ProfilePicture="{x:Bind ViewModel.SelectedSync.Drive.Account.User.GetAvatarImageSource(44), Mode=OneWay}"
                                       Height="44"
                                       Width="44" />
                            <ToolTipService.ToolTip>
                                <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Account.User.Name, Mode=OneWay}"
                                     Placement="Right" />
                            </ToolTipService.ToolTip>
                        </Button>

                    </Border>
                    <!-- Person Picture Button overlay -->
                    <Border x:Name="PersonPictureButtonOverlay"
                            Canvas.ZIndex="1"
                            Canvas.Left="0.8"
                            Canvas.Top="0.8"
                            Height="45"
                            Width="45"
                            Background="{ThemeResource SystemFillColorAttentionBrush}"
                            Opacity="0"
                            CornerRadius="100"
                            IsHitTestVisible="False">
                        <FontIcon x:Name="PersonPictureButtonOverlayIcon"
                                  Glyph="&#xE713;"
                                  Foreground="{ThemeResource TextFillColorInverseBrush}"
                                  Opacity="0"
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" 
                                  IsHitTestVisible="False"/>
                    </Border>

                    <!-- Sync button -->
                    <Button Canvas.ZIndex="3"
                            Canvas.Left="30"
                            Canvas.Top="30"
                            Height="20"
                            Width="20"
                            Padding="0"
                            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Circle}"
                            Click="SyncIconButton_Click"
                            PointerEntered="SyncIconButton_PointerEntered"
                            PointerExited="SyncIconButton_PointerExited">
                        <controls:SyncIcon Sync="{x:Bind ViewModel.SelectedSync, Mode=OneWay}"
                                           Height="12"
                                           Width="12" />
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind ViewModel.SelectedSync.Drive.Name, Mode=OneWay}"
                                     Placement="Right" />
                        </ToolTipService.ToolTip>
                    </Button>
                    <!-- Sync button overlay -->
                    <Border x:Name="SyncIconButtonOverlay"
                            Canvas.ZIndex="4"
                            Canvas.Left="30"
                            Canvas.Top="30"
                            Height="20"
                            Width="20"
                            Background="{ThemeResource SystemFillColorAttentionBrush}"
                            Opacity="0"
                            CornerRadius="100"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" >
                        <FontIcon x:Name="SyncIconButtonOverlayIcon"
                                  Glyph="&#xE713;"
                                  Foreground="{ThemeResource TextFillColorInverseBrush}"
                                  Opacity="0"
                                  FontSize="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" 
                                  IsHitTestVisible="False"/>
                    </Border>
                </Canvas>
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="FavoritesButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Actions.star}"
                                                  Foreground="{ThemeResource SystemFillColorAttentionBrush}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderFavorites')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>
                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="SharedButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-share}"
                                                  Foreground="{ThemeResource SystemFillColorAttentionBrush}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderShares')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="OpenDriveOnlineButton_Click">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                <controls:SvgIcon Height="13"
                                                  Width="13"
                                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive-outline}"
                                                  Foreground="{ThemeResource SystemFillColorAttentionBrush}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('buttonKDriveOnline')}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                            </StackPanel>

                            <controls:SvgIcon Grid.Column="1"
                                              Height="10"
                                              Width="10"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Right"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Click="TrashButton_Click">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon Height="13"
                                          Width="13"
                                          UriString="{StaticResource Infomaniak.DS.Icons.Actions.trashbin}"
                                          Foreground="{ThemeResource SystemFillColorAttentionBrush}" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('folderTrash')}"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                    </StackPanel>
                    <controls:SvgIcon Grid.Column="1"
                                      Height="10"
                                      Width="10"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}" />
                </Grid>
            </Button>

        </Grid>
    </Border>

</UserControl>
