<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:FilePathToIconConverter x:Key="FilePathToIconConverter" />
        <converters:StringPathToFileNameConverter x:Key="StringPathToFileNameConverter" />
        <converters:BytesToHumanReadableStringConverter x:Key="BytesToHumanReadableStringConverter" />
        <converters:DateTimeToTimeAgoConverter x:Key="DateTimeToTimeAgoConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />

        <!-- File template -->
        <DataTemplate x:Key="FileTemplate"
                      x:DataType="local:ISearchBoxResultItem">
            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                  ToolTipService.Placement="Right"
                  Background="Transparent"
                  PointerEntered="Template_PointerEntered"
                  PointerExited="Template_PointerExited"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XS}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <local:SvgIcon Grid.Column="0"
                               Grid.Row="0"
                               Width="16"
                               Height="16"
                               UriString="{x:Bind SearchItem.Name, Converter={StaticResource FilePathToIconConverter}}" />

                <TextBlock Grid.Column="1"
                           Grid.Row="0"
                           Text="{x:Bind SearchItem.Name}"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Left">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind SearchItem.Name}" />
                    </ToolTipService.ToolTip>
                </TextBlock>

                <TextBlock Grid.Column="1"
                           Grid.Row="1"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="{x:Bind SearchItem.Path, Converter={StaticResource StringPathToFileNameConverter}, ConverterParameter='Parent=True'}" />
                    <Run Text=" -" />
                    <Run Text="{x:Bind SearchItem.ModifiedTime, Converter={StaticResource DateTimeToTimeAgoConverter}, ConverterParameter='Format=Ago'}" />
                    <Run Text="-" />
                    <Run Text="{x:Bind SearchItem.Size, Converter={StaticResource BytesToHumanReadableStringConverter}}" />
                </TextBlock>

                <local:SvgIcon Grid.Column="2"
                               Grid.Row="0"
                               Width="10"
                               HorizontalAlignment="Right"
                               UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding ShowUnavailableState, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

            </Grid>
        </DataTemplate>

        <!-- Directory template -->
        <DataTemplate x:Key="FolderTemplate"
                      x:DataType="local:ISearchBoxResultItem">
            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                  Background="Transparent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ToolTipService.Placement="Right"
                  PointerEntered="Template_PointerEntered"
                  PointerExited="Template_PointerExited"
                  Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XS}">
                <ToolTipService.ToolTip>
                    <ToolTip Visibility="{x:Bind SearchItem.IsAvailableLocally, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}"
                             Content="{x:Bind kDrive:Localizer.Instance.GetString('itemUnavailableBrowserFallback'), Mode=OneWay}" />
                </ToolTipService.ToolTip>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <local:SvgIcon Grid.Column="0"
                               Grid.Row="0"
                               Width="16"
                               UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder}" />

                <TextBlock Grid.Column="1"
                           Grid.Row="0"
                           Text="{x:Bind SearchItem.Name}"
                           TextTrimming="CharacterEllipsis">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind SearchItem.Name}" />
                    </ToolTipService.ToolTip>
                </TextBlock>

                <TextBlock Grid.Column="1"
                           Grid.Row="1"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="{x:Bind SearchItem.Path, Converter={StaticResource StringPathToFileNameConverter}, ConverterParameter='Parent=True'}" />
                    <Run Text="-" />
                    <Run Text="{x:Bind SearchItem.ModifiedTime, Converter={StaticResource DateTimeToTimeAgoConverter}, ConverterParameter='Format=Ago'}" />
                </TextBlock>
                <local:SvgIcon Grid.Column="2"
                               Grid.Row="0"
                               Width="10"
                               HorizontalAlignment="Right"
                               Margin="{StaticResource Infomaniak.Style.Thickness.Left.XS}"
                               UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding ShowUnavailableState, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
            </Grid>
        </DataTemplate>

        <!-- No result template -->
        <DataTemplate x:Key="NotFoundTemplate"
                      x:DataType="local:ISearchBoxResultItem">
            <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XL}"
                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.S}"
                  DataContextChanged="SearchResultItem_DataContextChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <local:SvgIcon UriString="{ThemeResource Infomaniak.Custom.Images.servin}"
                               Height="100"
                               HorizontalAlignment="Center" />
                <TextBlock Grid.Row="1"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('noResultsFound'), Mode=OneWay}"
                           HorizontalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <!-- Loader template -->
        <DataTemplate x:Key="LoaderTemplate"
                      x:DataType="local:ISearchBoxResultItem">
            <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XS}"
                  ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                  DataContextChanged="SearchResultItem_DataContextChanged">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <local:ContentLoader Grid.Column="0"
                                     Grid.Row="0"
                                     Height="16"
                                     Width="16"
                                     IsLoading="True"
                                     CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.XS}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center" />

                <local:ContentLoader Grid.Column="1"
                                     Grid.Row="0"
                                     Height="16"
                                     Width="80"
                                     IsLoading="True"
                                     CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.XS}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center" />

                <local:ContentLoader Grid.Column="1"
                                     Grid.Row="1"
                                     Height="16"
                                     Width="230"
                                     IsLoading="True"
                                     CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.XS}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center" />

            </Grid>
        </DataTemplate>

        <!-- Template selector -->
        <local:SearchBoxResultItemTemplateSelector x:Key="SearchBoxResultItemTemplateSelector"
                                                   FileTemplate="{StaticResource FileTemplate}"
                                                   FolderTemplate="{StaticResource FolderTemplate}"
                                                   LoaderTemplate="{StaticResource LoaderTemplate}"
                                                   NotFoundTemplate="{StaticResource NotFoundTemplate}" />
    </UserControl.Resources>

    <AutoSuggestBox x:Name="TitleBarSearchBox"
                    QueryIcon="Find"
                    PlaceholderText="{x:Bind kDrive:Localizer.Instance.GetString('searchBoxPlaceholder', ViewModel.SelectedSync.Drive.Name), Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                    BorderThickness="1"
                    TextChanged="SearchBox_TextChanged"
                    ItemTemplateSelector="{StaticResource SearchBoxResultItemTemplateSelector}"
                    UpdateTextOnSelect="False"
                    SuggestionChosen="TitleBarSearchBox_SuggestionChosen"
                    QuerySubmitted="TitleBarSearchBox_QuerySubmitted"
                    Visibility="{x:Bind ViewModel.SelectedSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}" />
</UserControl>
