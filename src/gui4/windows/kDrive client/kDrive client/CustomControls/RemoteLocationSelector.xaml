<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.RemoteLocationSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             Loaded="RemoteLocationSelector_Loaded"
             Unloaded="RemoteLocationSelector_Unloaded">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BytesToHumanReadableStringConverter x:Key="BytesToHumanReadableStringConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />

        <Style x:Key="TreeItemGridStyle"
               TargetType="Grid">
            <Setter Property="ColumnSpacing"
                    Value="{StaticResource Infomaniak.Style.Spacing.XS}" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="{StaticResource Infomaniak.Style.Thickness.Left.XXS}" />
            <Setter Property="Padding"
                    Value="{StaticResource Infomaniak.Style.Thickness.Right.S}" />
        </Style>

        <DataTemplate x:DataType="local:TreeItem2"
                      x:Key="FolderTemplate">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                          IsExpanded="{x:Bind IsRoot}"
                          PointerEntered="TreeViewItem_PointerEntered"
                          PointerExited="TreeViewItem_PointerExited">
                <Grid Style="{StaticResource TreeItemGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="28" />
                    </Grid.ColumnDefinitions>

                    <local:SvgIcon Grid.Column="0"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                   Foreground="{x:Bind Drive.Color, Converter={StaticResource ColorToBrushConverter}}"
                                   Visibility="{x:Bind IsRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   VerticalAlignment="Center"
                                   Height="16"
                                   Width="16" />

                    <local:SvgIcon Grid.Column="0"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder}"
                                   Foreground="{ThemeResource TextFillColorPrimary}"
                                   Visibility="{x:Bind IsNotRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   VerticalAlignment="Center"
                                   Height="16"
                                   Width="16" />

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Node.Name}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               MaxWidth="220">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind Node.Name}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>

                    <ProgressRing Grid.Column="2"
                                  Visibility="{x:Bind IsLoadingChildren, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                  IsIndeterminate="True"
                                  Height="16"
                                  VerticalAlignment="Center"
                                  Width="16" />

                    <local:ContentLoader Grid.Column="3"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         IsLoading="{x:Bind Node.IsLoadingSize, Mode=OneWay}"
                                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                                         LoaderMinHeight="16"
                                         LoaderMinWidth="40"
                                         DataContextChanged="SizeContentLoader_DataContextChanged"
                                         Visibility="{x:Bind IsNotRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <local:ContentLoader.LoaderContent>
                            <TextBlock Text="{x:Bind Node.Size, Converter={StaticResource BytesToHumanReadableStringConverter}, Mode=OneWay}"
                                       VerticalAlignment="Center" />
                        </local:ContentLoader.LoaderContent>
                    </local:ContentLoader>

                    <Button Grid.Column="4"
                            VerticalAlignment="Center"
                            Style="{ThemeResource SubtleButtonStyle}"
                            Padding="0"
                            IsEnabled="{x:Bind CanCreateSubFolder, Mode=OneWay}"
                            Visibility="{x:Bind CreateSubFolderButtonVisibility, Mode=OneWay}"
                            Click="CreateFolderButton_Click">
                        <local:SvgIcon Height="16"
                                       Width="16"
                                       UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-circle-plus}"
                                       Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                       IsIconEnabled="{x:Bind CanCreateSubFolder, Mode=OneWay}" />
                    </Button>
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:DataType="local:TreeItem2"
                      x:Key="NewNodeTemplate">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}">
                <Grid Style="{StaticResource TreeItemGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <local:SvgIcon Grid.Column="0"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder}"
                                   Foreground="{ThemeResource TextFillColorPrimary}"
                                   VerticalAlignment="Center"
                                   Height="16"
                                   Width="16" />

                    <controls:ContentLoader Grid.Column="1"
                                            IsLoading="False"
                                            LoaderMinWidth="150"
                                            Width="150"
                                            LoaderMinHeight="24"
                                            HorizontalAlignment="Left"
                                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.XS}">
                        <controls:ContentLoader.LoaderContent>
                            <TextBox PlaceholderText="{x:Bind kDrive:Localizer.Instance.GetString('labelNewFolder')}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                     MinWidth="150"
                                     MaxWidth="220"
                                     LostFocus="NewItemTextBox_LostFocus"
                                     KeyDown="NewItemTextBox_KeyDown" />
                        </controls:ContentLoader.LoaderContent>
                    </controls:ContentLoader>

                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:DataType="local:TreeItem2"
                      x:Key="AccessDeniedDirectoryTemplate">
            <TreeViewItem HorizontalAlignment="Stretch"
                          MinHeight="24">
                <ToolTipService.ToolTip>
                    <ToolTip Content="{x:Bind kDrive:Localizer.Instance.GetString('unauthorizedAccess')}" />
                </ToolTipService.ToolTip>
                <Grid Style="{StaticResource TreeItemGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <local:SvgIcon Grid.Column="0"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-block}"
                                   Foreground="{ThemeResource TextFillColorTertiary}"
                                   VerticalAlignment="Center"
                                   Height="16"
                                   Width="16" />

                    <TextBlock Grid.Column="1"
                               Foreground="{ThemeResource TextFillColorTertiary}"
                               Text="{x:Bind Node.Name}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               MaxWidth="220">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind Node.Name}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>

                    <!-- Empty placeholder for ProgressRing -->
                    <Grid Grid.Column="2"
                          Width="16"
                          Height="16" />

                    <!-- Empty placeholder for ContentLoader -->
                    <Grid Grid.Column="3"
                          MinWidth="40"
                          MinHeight="14" />

                    <local:SvgIcon Grid.Column="4"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-block}"
                                   Foreground="{ThemeResource TextFillColorTertiary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Height="16"
                                   Width="16"
                                   Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.XXS}" />
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <local:FolderTreeViewItemTemplateSelector2 x:Key="FolderTreeViewItemTemplateSelector_"
                                                   FolderTemplate="{StaticResource FolderTemplate}"
                                                   AccessDeniedTemplate="{StaticResource AccessDeniedDirectoryTemplate}"
                                                   NewNodeTemplate="{StaticResource NewNodeTemplate}" />
    </UserControl.Resources>

    <local:ContentLoader x:Name="TreeViewContentLoader"
                         IsLoading="{x:Bind IsLoading, Mode=OneWay}"
                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                         LoaderMinHeight="200">
        <local:ContentLoader.LoaderContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0"
                           Grid.Row="0"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('labelName')}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="{StaticResource Infomaniak.Style.Thickness.Left.S}" />
                <TextBlock Grid.Column="1"
                           Grid.Row="0"
                           HorizontalAlignment="Right"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('labelsize')}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,56,0" />

                <TreeView x:Name="FolderTree"
                          Grid.ColumnSpan="2"
                          Grid.Row="1"
                          ItemsSource="{x:Bind _rootLevelItems, Mode=OneWay}"
                          SelectionMode="Single"
                          HorizontalAlignment="Stretch"
                          Expanding="TreeView_Expanding"
                          CanDrag="False"
                          CanDragItems="False"
                          CanReorderItems="False"
                          ItemTemplateSelector="{StaticResource FolderTreeViewItemTemplateSelector_}"
                          SelectionChanged="FolderTree_SelectionChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="VerticalContentAlignment"
                                    Value="Center" />
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </local:ContentLoader.LoaderContent>
    </local:ContentLoader>
</UserControl>
