<UserControl x:Class="Infomaniak.kDrive.CustomControls.SyncExclusionSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:lottie="using:CommunityToolkit.WinUI.Lottie"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             Loaded="SyncExclusionSelector_Loaded">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BytesToHumanReadableStringConverter x:Key="BytesToHumanReadableStringConverter" />

        <DataTemplate x:DataType="local:TreeItem"
                      x:Key="DirectoryTemplate">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                          DataContextChanged="TreeViewItem_DataContextChanged">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                              IsThreeState="True"
                              MinWidth="0"
                              MinHeight="0"
                              Tag="{x:Bind}"
                              Click="CheckBox_Click" />
                    <local:SvgIcon Grid.Column="1"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-outline}"
                                   Foreground="{ThemeResource TextFillColorPrimary}"
                                   Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind Node.Name}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="220">
                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind Node.Name}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <ProgressRing Grid.Column="3"
                                  Visibility="{x:Bind IsLoadingChildren, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                  IsIndeterminate="True"
                                  Height="16"
                                  Width="Auto" />

                    <local:ContentLoader Grid.Column="4"
                                         HorizontalAlignment="Right"
                                         IsLoading="{x:Bind Node.IsLoadingSize, Mode=OneWay}"
                                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                                         LoaderMinWidth="60"
                                         LoaderMinHeight="16"
                                         Margin="{StaticResource Infomaniak.Style.Thickness.Right.M}">
                        <local:ContentLoader.LoaderContent>
                            <TextBlock Text="{x:Bind Node.Size, Converter={StaticResource BytesToHumanReadableStringConverter}, Mode=OneWay}"
                                       HorizontalAlignment="Right" />
                        </local:ContentLoader.LoaderContent>
                    </local:ContentLoader>
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:DataType="local:TreeItem"
                      x:Key="AccessDeneidDirectoryTemplate">
            <TreeViewItem HorizontalAlignment="Stretch">
                <ToolTipService.ToolTip>
                    <ToolTip Content="{x:Bind kDrive:Localizer.Instance.GetString('unauthorizedAccess')}" />
                </ToolTipService.ToolTip>
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="False"
                              IsEnabled="False"
                              MinWidth="0"
                              MinHeight="0" />
                    <local:SvgIcon Grid.Column="1"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-block}"
                                   Foreground="{ThemeResource TextFillColorTertiary}"
                                   Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />

                    <TextBlock Grid.Column="2"
                               Foreground="{ThemeResource TextFillColorTertiary}"
                               Text="{x:Bind Node.Name}" />

                    <local:SvgIcon Grid.Column="3"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-block}"
                                   Foreground="{ThemeResource TextFillColorTertiary}"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                   Margin="{StaticResource Infomaniak.Style.Thickness.Right.L}" />
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <local:FolderTreeViewItemTemplateSelector x:Key="FolderTreeViewItemTemplateSelector_"
                                                  DirectoryTemplate="{StaticResource DirectoryTemplate}"
                                                  AccessDeniedTemplate="{StaticResource AccessDeneidDirectoryTemplate}" />
    </UserControl.Resources>

    <local:ContentLoader x:Name="TreeViewContentLoader"
                         IsLoading="{x:Bind IsLoading, Mode=OneWay}"
                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                         LoaderMinHeight="200">
        <local:ContentLoader.LoaderContent>
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <!-- Title -->
                    <RowDefinition Height="Auto" />

                    <!-- Remote folder exclusion -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('selectFoldersToSyncDescription')}"
                           TextWrapping="WrapWholeWords"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind HasSubDirectory, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                <StackPanel Grid.Row="1"
                            Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                            Visibility="{x:Bind HasSubDirectory, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelSyncExclusionEmptyTitle')}"
                               Foreground="{ThemeResource TextFillColorPrimary}" />
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelSyncExclusionEmptyDescription')}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      Grid.Row="1"
                      Visibility="{x:Bind HasSubDirectory, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0"
                          RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0"
                                  Margin="{StaticResource Infomaniak.Style.Thickness.Left.L}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Grid.Column="0"
                                              IsChecked="{x:Bind RootTreeItem.IsSelected, Mode=OneWay}"
                                              IsThreeState="True"
                                              MinWidth="0"
                                              MinHeight="0"
                                              Click="CheckBox_Click"
                                              DataContext="{x:Bind RootTreeItem, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelName')}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Column="1"
                                  HorizontalAlignment="Right"
                                  Margin="{StaticResource Infomaniak.Style.Thickness.Right.L}">
                            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelSize')}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <TreeView x:Name="FolderTree"
                                      Grid.ColumnSpan="2"
                                      Grid.Row="1"
                                      ItemsSource="{x:Bind _rootLevelItems, Mode=OneWay}"
                                      SelectionMode="None"
                                      HorizontalAlignment="Stretch"
                                      CanDrag="False"
                                      CanDragItems="False"
                                      CanReorderItems="False"
                                      ItemTemplateSelector="{StaticResource FolderTreeViewItemTemplateSelector_}" />

                    </Grid>
                    <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource Infomaniak.Style.Spacing.S}"
                                    HorizontalAlignment="Right"
                                    Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                                    Visibility="{x:Bind ShowSaveMenu, Mode=OneWay}">
                        <Button Click="CancelSyncSelection_click"
                                    Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonCancel')}"
                                    IsEnabled="{x:Bind IsLoading, Converter={StaticResource BooleanToInvertedBooleanConverter} , Mode=OneWay}" />
                        <Button Style="{ThemeResource AccentButtonStyle}"
                                    Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSaveMyChoices')}"
                                    Click="SaveSyncSelection_click"
                                    IsEnabled="{x:Bind IsLoading, Converter={StaticResource BooleanToInvertedBooleanConverter} , Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </local:ContentLoader.LoaderContent>
    </local:ContentLoader>
</UserControl>
