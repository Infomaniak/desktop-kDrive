<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.SyncExclusionSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:lottie="using:CommunityToolkit.WinUI.Lottie"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BytesToHumanReadableStringConverter x:Key="BytesToHumanReadableStringConverter" />
        <DataTemplate x:DataType="local:TreeItem"
                      x:Key="DirectoryTemplate">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                          HorizontalAlignment="Stretch">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                              IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                              IsThreeState="True"
                              MinWidth="0"
                              MinHeight="0"
                              Tag="{x:Bind}"
                              Checked="CheckBox_Checked"
                              Unchecked="CheckBox_Unchecked"
                              Indeterminate="CheckBox_Indeterminate" />
                    <local:SvgIcon Grid.Column="1"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder}"
                                   Foreground="{ThemeResource TextFillColorPrimary}"
                                   Height="16" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind Node.Name}" />
                    <ProgressRing Grid.Column="3"
                                  Visibility="{x:Bind IsLoadingChildren, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                  IsIndeterminate="True"
                                  Height="16"
                                  Width="auto" />

                    <local:ContentLoader Grid.Column="4"
                                         HorizontalAlignment="Right"
                                         IsLoading="{x:Bind Node.IsLoadingSize, Mode=OneWay}"
                                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.S}"
                                         MinWidth="60"
                                         Margin="{StaticResource Infomaniak.Style.Thickness.Right.M}"
                                         DataContextChanged="SizeContentLoader_DataContextChanged">
                        <local:ContentLoader.LoaderContent>
                            <TextBlock Text="{x:Bind Node.Size, Converter={StaticResource BytesToHumanReadableStringConverter}, Mode=OneWay}"
                                       MinWidth="60" />
                        </local:ContentLoader.LoaderContent>
                    </local:ContentLoader>
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <DataTemplate x:DataType="local:TreeItem"
                      x:Key="FileTemplate">
            <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                          IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                          HorizontalAlignment="Stretch">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                              IsThreeState="False"
                              IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                              MinWidth="0"
                              MinHeight="0"
                              Tag="{x:Bind}"
                              Checked="CheckBox_Checked"
                              Unchecked="CheckBox_Unchecked" />

                    <local:SvgIcon Grid.Column="1"
                                   UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-open-file}"
                                   Foreground="{ThemeResource TextFillColorPrimary}"
                                   Height="16" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind Node.Name}" />

                    <TextBlock Grid.Column="3"
                               Text="-"
                               HorizontalAlignment="Right"
                               MinWidth="60"
                               Margin="{StaticResource Infomaniak.Style.Thickness.Right.M}" />
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <local:NodeTypeTemplateSelector x:Key="NodeTypeTemplateSelector"
                                        DirectoryTemplate="{StaticResource DirectoryTemplate}"
                                        FileTemplate="{StaticResource FileTemplate}" />
    </UserControl.Resources>
    <local:ContentLoader x:Name="TreeViewContentLoader"
                         IsLoading="{x:Bind IsLoading, Mode=OneWay}"
                         CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.S}"
                         MinLoaderHeight="200">
        <local:ContentLoader.LoaderContent>
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0"
                      Margin="{StaticResource Infomaniak.Style.Thickness.Left.L}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{x:Bind RootTreeItem.IsSelected, Mode=OneWay}"
                                  IsEnabled="{x:Bind RootTreeItem.IsEnabled, Mode=OneWay}"
                                  IsThreeState="True"
                                  MinWidth="0"
                                  MinHeight="0"
                                  Checked="CheckBox_Checked"
                                  Unchecked="CheckBox_Unchecked"
                                  Indeterminate="CheckBox_Indeterminate"
                                  DataContext="{x:Bind RootTreeItem, Mode=OneWay}"/>
                        <TextBlock x:Uid="CC_SyncExclusionSelector_Header_Name"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1"
                      HorizontalAlignment="Right"
                      Margin="{StaticResource Infomaniak.Style.Thickness.Right.L}">
                    <TextBlock x:Uid="CC_SyncExclusionSelector_Header_Size" />
                </Grid>

                <TreeView x:Name="FolderTree"
                          Grid.ColumnSpan="2"
                          Grid.Row="1"
                          ItemsSource="{x:Bind _rootLevelItems, Mode=OneWay}"
                          IsEnabled="{x:Bind StatePropagationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                          SelectionMode="None"
                          HorizontalAlignment="Stretch"
                          Expanding="TreeView_Expanding"
                          CanDrag="False"
                          CanDragItems="False"
                          CanReorderItems="False"
                          ItemTemplateSelector="{StaticResource NodeTypeTemplateSelector}" />

            </Grid>
        </local:ContentLoader.LoaderContent>
    </local:ContentLoader>
</UserControl>
