<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.SyncStartPauseButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>

        <!-- Data templates for different button states -->
        <DataTemplate x:Key="PauseButtonTemplate">
            <local:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Media.pause}"
                           Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </DataTemplate>
        <DataTemplate x:Key="StartButtonTemplate">
            <local:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Media.play}"
                           Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </DataTemplate>
        <DataTemplate x:Key="LoadingButtonTemplate">
            <Viewbox Stretch="Uniform">
                <ProgressRing />
            </Viewbox>
        </DataTemplate>
        <local:StartPauseButtonTemplateSelector x:Key="StartPauseButtonTemplateSelector"
                                                PauseButtonTemplate="{StaticResource PauseButtonTemplate}"
                                                StartButtonTemplate="{StaticResource StartButtonTemplate}"
                                                LoadingButtonTemplate="{StaticResource LoadingButtonTemplate}" />

        <!-- Converter to enable/disable the button based on sync status -->
        <local:SyncToButtonEnabledConverter x:Key="SyncToButtonEnabledConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />

    </UserControl.Resources>

    <StackPanel Orientation="Horizontal">
        <Button x:Name="StartPauseButton"
                Click="StartPauseButton_Click"
                ContentTemplateSelector="{StaticResource StartPauseButtonTemplateSelector}"
                Content="{x:Bind ViewModel.SelectedSync.SyncStatus, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.SelectedSync, Converter={StaticResource SyncToButtonEnabledConverter}, Mode=OneWay}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                Visibility="{x:Bind ViewModel.SelectedSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}"/>
    </StackPanel>
</UserControl>
