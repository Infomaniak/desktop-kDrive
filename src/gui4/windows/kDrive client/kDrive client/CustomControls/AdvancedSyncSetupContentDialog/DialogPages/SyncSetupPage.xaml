<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.AdvancedSyncSetupContentDialog.SyncSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:controlsErrors="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:templateSelectors="using:Infomaniak.kDrive.TemplateSelectors"
      xmlns:kDrive="using:Infomaniak.kDrive"
      Unloaded="Page_Unloaded"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToIntegerConverter x:Key="BooleanToIntegerConverter" />
        <converters:DateTimeToTimeAgoConverter x:Key="DateTimeToTimeAgoConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:StringPathToFileNameConverter x:Key="StringPathToFileNameConverter" />
        <converters:SyncTypeToBoolConverter x:Key="SyncTypeToBoolConverter" />
    </Page.Resources>
    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>
    <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />

            <!-- Local folder -->
            <RowDefinition Height="Auto" />

            <!-- Exclusion -->
            <RowDefinition Height="Auto" />

            <!-- Lite sync -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{x:Bind kDrive:Localizer.Instance.GetString('addAdvancedSyncDialogTitle')}"
                   TextWrapping="WrapWholeWords"
                   Style="{StaticResource SubtitleTextBlockStyle}" />

        <!-- Local folder -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('addAdvancedSyncLocalFolderTitle')}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('addAdvancedSyncLocalFolderDescription')}"
                               TextWrapping="WrapWholeWords"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.LocalPath, Mode=OneWay}" />
                    </ToolTipService.ToolTip>

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSelectFolder')}"
                            Click="SelectLocalFolder_Click" />

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                            HorizontalAlignment="Left"
                            Visibility="{x:Bind IsStringEmptyToVisibility(AdvancedSyncSetupContentDialogVM.NewSync.LocalPath, x:True), Mode=OneWay}">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:SvgIcon Grid.Column="0"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-outline}"
                                              Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                              Foreground="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}" />

                            <TextBlock Grid.Column="1"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Text="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.LocalPath, Converter={StaticResource StringPathToFileNameConverter} , Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Remote folder -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('addAdvancedSyncRemoteFolderTitle')}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('addAdvancedSyncRemoteFolderDescription')}"
                               TextWrapping="WrapWholeWords"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.RemotePath, Mode=OneWay}" />
                    </ToolTipService.ToolTip>

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSelectLocation')}"
                            Click="RemoteLocationButton_Click" />

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                            HorizontalAlignment="Left"
                            Visibility="{x:Bind IsStringEmptyToVisibility(AdvancedSyncSetupContentDialogVM.NewSync.RemotePath, x:True), Mode=OneWay}">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <controls:SvgIcon Grid.Column="0"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-outline}"
                                              Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                              Foreground="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}" />

                            <TextBlock Grid.Column="1"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Text="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.RemotePath, Converter={StaticResource StringPathToFileNameConverter} , Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!--Lite sync -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                Visibility="{x:Bind IsStringEmptyToVisibility(AdvancedSyncSetupContentDialogVM.NewSync.LocalPath, x:True), Mode=OneWay}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsLiteSyncTitle')}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsLiteSyncDescription')}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <ToggleSwitch Grid.Row="1"
                              IsEnabled="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.SupportsLiteSync , Mode=OneWay}"
                              IsOn="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.SyncType, Converter={StaticResource SyncTypeToBoolConverter}, Mode=TwoWay}" />

                <TextBlock Grid.ColumnSpan="2"
                           Grid.Row="2"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('liteSyncUnavailableDescription')}"
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Visibility="{x:Bind AdvancedSyncSetupContentDialogVM.NewSync.SupportsLiteSync , Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
