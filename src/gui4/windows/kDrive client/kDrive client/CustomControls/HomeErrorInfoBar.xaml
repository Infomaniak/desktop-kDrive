<UserControl x:Class="Infomaniak.kDrive.CustomControls.HomeErrorInfoBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <InfoBar x:Name="kDriveFullInfoBar"
                 IsOpen="{x:Bind ControlViewModel.ShowDriveFullError, Mode=OneWay}"
                 Title="{x:Bind kDrive:Localizer.Instance.GetString('informationBlockKDriveFullTitle')}"
                 Message="{x:Bind kDrive:Localizer.Instance.GetString('informationBlockKDriveFullSubtitle')}"
                 IsClosable="True"
                 Closed="kDriveFullInfoBar_Closed">
            <InfoBar.IconSource>
                <controls:SvgIconSource UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive-outline}"
                                        Foreground="{ThemeResource SystemAccentColor}" />
            </InfoBar.IconSource>
            <InfoBar.ActionButton>

                <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonAddStorage')}"
                        Click="kDriveFullInfoBar_Click"
                        Visibility="{x:Bind AppViewModel.SelectedSync.Drive.IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <InfoBar x:Name="TmpDirAccessError"
                 IsOpen="{x:Bind ControlViewModel.ShowTmpDirAccessError, Mode=OneWay}"
                 Title="{x:Bind kDrive:Localizer.Instance.GetString('informationBlockTmpDirAccessErrorTitle')}"
                 Message="{x:Bind kDrive:Localizer.Instance.GetString('informationBlockTmpDirAccessErrorSubtitle')}"
                 IsClosable="True"
                 Closed="TmpDirAccessError_Closed">
            <InfoBar.IconSource>
                <controls:SvgIconSource UriString="{StaticResource Infomaniak.DS.Icons.Network.cloud-offline}"
                                        Foreground="{ThemeResource SystemAccentColor}" />
            </InfoBar.IconSource>
            <InfoBar.ActionButton>
                <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonCloseKDrive')}"
                        Click="TmpDirAccessError_Click" />
            </InfoBar.ActionButton>
        </InfoBar>
    </Grid>
</UserControl>
