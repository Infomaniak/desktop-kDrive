<UserControl x:Class="Infomaniak.kDrive.CustomControls.Errors.DefaultError"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
    </UserControl.Resources>

    <local:ErrorCard x:Name="ErrorCard"
                     Title="{x:Bind kDrive:Localizer.Instance.GetString('defaultErrorTitle')}"
                     Description="{x:Bind kDrive:Localizer.Instance.GetString('defaultErrorDescription')}"
                     ActionText="{x:Bind kDrive:Localizer.Instance.GetString('needHelpSetting')}"
                     ActionClick="ErrorCard_ActionClick"
                     Error="{x:Bind Error}">
        <local:ErrorCard.CustomContent>

            <!-- Technical Details Expander -->
            <Expander x:Name="DetailsExpander"
                      HorizontalAlignment="Stretch"
                      Margin="{StaticResource Infomaniak.Style.Thickness.Top.L}">
                <Expander.Header>
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('defaultErrorDetailsLabel')}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Expander.Header>

                <ItemsRepeater ItemsSource="{x:Bind Properties, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:DefaultErrorProperty">
                            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                                  HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Name}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text=": " />
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Value}"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Expander>
        </local:ErrorCard.CustomContent>
    </local:ErrorCard>
</UserControl>