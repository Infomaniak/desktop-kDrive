<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Infomaniak.kDrive.CustomControls.Errors.Templates.SyncPal.DataErrorSyncDirChanged"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:kDrive="using:Infomaniak.kDrive"
             Unloaded="UserControl_Unloaded"
             mc:Ignorable="d">
    <local:ErrorCard x:Name="ErrorCard"
                     Title="{x:Bind kDrive:Localizer.Instance.GetString('errSystemSyncDirMissingTitle')}"
                     Description="{x:Bind kDrive:Localizer.Instance.GetString('errSystemSyncDirChanged')}"
                     ActionText="{x:Bind kDrive:Localizer.Instance.GetString('buttonErrorResolutionTip')}"
                     ActionClick="ErrorCard_ActionClick"
                     Error="{x:Bind Error}" />
                    <!-- The title is the same as the one of SystemErrorSyncDirDiskMissing on purpose, as the error is basically the same, but with a different cause. -->
</UserControl>
