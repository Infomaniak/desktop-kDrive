<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.CustomControls.Errors.SystemErrorSyncDirAccessErrorDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}"
                MinWidth="480">
        <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('dialogSystemErrorSyncDirAccessErrorDescription')}" />

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderMovedOrRenamed')}"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-right}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}" />
                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelRestoreToOriginalLocation')}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelAccessRightsModified')}"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-right}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}" />

                        <TextBlock x:Name="AccessRightsModifiedTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderDeleted')}"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-right}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}" />
                        <TextBlock x:Name="FolderDeletedTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelOriginalLocation')}"
                       FontWeight="SemiBold" />

            <controls:ItemPathPresenter AbsoluteItemPath="{x:Bind Error.Sync.LocalPath}"
                                        HorizontalAlignment="Stretch" />
        </StackPanel>
    </StackPanel>
</Page>
