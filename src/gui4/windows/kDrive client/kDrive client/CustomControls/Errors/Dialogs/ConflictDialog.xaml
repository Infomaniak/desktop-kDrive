<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.CustomControls.Errors.ConflictDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.M}"
                MinWidth="540">

        <!-- File name badge -->
        <controls:ItemNamePresenter ItemPath="{x:Bind FilePath}"
                                    NodeType="{x:Bind Error.NodeType}" />

        <!-- Question -->
        <TextBlock Text="Quelle version souhaitez-vous garder ?"
                   Style="{StaticResource Infomaniak.Style.TextBlock.BodyStrong}"
                   TextWrapping="Wrap" />

        <!-- Version cards -->
        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Online version card (selected) -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource Infomaniak.Style.Color.Product.DefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">

                    <!-- Header: cloud icon + label + badge + view button -->
                    <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <controls:SvgIcon Grid.Column="0"
                                          UriString="{StaticResource Infomaniak.Custom.Icons.Devices.cloud-sync}"
                                          Width="16"
                                          Height="16"
                                          VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="En ligne"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.BodyStrong}"
                                   VerticalAlignment="Center" />

                        <!-- "Plus récente" badge -->
                        <Border Grid.Column="2"
                                BorderBrush="{StaticResource Infomaniak.Style.Color.Product.DefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.XS}"
                                Padding="6,2"
                                VerticalAlignment="Center">
                            <TextBlock Text="Plus récente"
                                       Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                                       Foreground="{StaticResource Infomaniak.Style.Color.Product.DefaultBrush}" />
                        </Border>

                        <!-- View button -->
                        <Button Grid.Column="4"
                                Style="{StaticResource Infomaniak.Style.Button.WithoutBackground}"
                                Padding="4"
                                MinWidth="0"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE890;"
                                      FontSize="16"
                                      Foreground="{StaticResource Infomaniak.Style.Color.Product.DefaultBrush}" />
                        </Button>
                    </Grid>

                    <!-- Details -->
                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}">
                        <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Auteur"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Jeanne Ultou"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Taille"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="7 MB"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Date"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="22.05.2025  16:32"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <!-- Selected button -->
                    <Button Style="{StaticResource Infomaniak.Style.Button.WithBackground}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-check-outline}"
                                              Foreground="White"
                                              Width="16"
                                              Height="16" />
                            <TextBlock Text="Selectionné"
                                       Foreground="White" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Local version card (unselected) -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowRevealBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">

                    <!-- Header: computer icon + label + view button -->
                    <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <controls:SvgIcon Grid.Column="0"
                                          UriString="{StaticResource Infomaniak.DS.Icons.Devices.computer}"
                                          Width="16"
                                          Height="16"
                                          VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="Locale"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.BodyStrong}"
                                   VerticalAlignment="Center" />

                        <!-- View button -->
                        <Button Grid.Column="2"
                                Style="{StaticResource Infomaniak.Style.Button.WithoutBackground}"
                                Padding="4"
                                MinWidth="0"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE890;"
                                      FontSize="16"
                                      Foreground="{StaticResource Infomaniak.Style.Color.Product.DefaultBrush}" />
                        </Button>
                    </Grid>

                    <!-- Details -->
                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}">
                        <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Auteur"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Jeanne Ultou"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Taille"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="7 MB"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Date"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="22.05.2025  16:30"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <!-- Select button (unselected) -->
                    <Button Style="{StaticResource Infomaniak.Style.Button.Secondary}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Content="Selectionner" />
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</Page>
