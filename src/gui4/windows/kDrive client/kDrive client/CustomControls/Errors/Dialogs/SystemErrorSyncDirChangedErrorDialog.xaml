<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.CustomControls.Errors.SystemErrorSyncDirChangedErrorDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}"
                    MinWidth="480">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('dialogDataErrorSyncDirChangeDescription')}" />

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelNewDeviceDetected')}"
                               TextWrapping="WrapWholeWords"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelNewDeviceDetectedTip')}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderDisplacedOrModified')}"
                               TextWrapping="WrapWholeWords"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderDisplacedOrModifiedTip')}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderRecreatedOrReplaced')}"
                               TextWrapping="WrapWholeWords"
                               FontWeight="SemiBold" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelFolderRecreatedOrReplacedTip')}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelOriginalLocation')}"
                       FontWeight="SemiBold" />

            <controls:ItemPathPresenter AbsoluteItemPath="{x:Bind Error.Sync.LocalPath}"
                                        HorizontalAlignment="Stretch" />
        </StackPanel>
    </StackPanel>

</Page>
