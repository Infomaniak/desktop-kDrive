<UserControl x:Class="Infomaniak.kDrive.CustomControls.Errors.ErrorBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls.Errors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:Infomaniak.kDrive.Converters"
             xmlns:controls="using:Infomaniak.kDrive.CustomControls"
             xmlns:kDrive="using:Infomaniak.kDrive"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:IntegerToBooleanConverter x:Key="IntegerToBooleanConverter" />
    </UserControl.Resources>
    <InfoBar x:Name="InfoBar_"
             Title="{x:Bind kDrive:Localizer.Instance.GetStringWithPlural1i('winInformationBlockSynchroErrorTitle', ViewModel.SelectedSync.SyncErrors.Count, ViewModel.SelectedSync.SyncErrors.Count), Mode=OneWay}"
             Message="{x:Bind kDrive:Localizer.Instance.GetString('informationBlockSynchroErrorSubtitle')}"
             Severity="Informational"
             IsIconVisible="False"
             IsClosable="False"
             IsOpen="{x:Bind ViewModel.SelectedSync.SyncErrors.Count, Converter='{StaticResource IntegerToBooleanConverter}', Mode=OneWay}">
        <InfoBar.ActionButton>
            <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonFixErrors')}"
                    HorizontalAlignment="Right"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="InfoBarButton_Click" />
        </InfoBar.ActionButton>
    </InfoBar>
</UserControl>
