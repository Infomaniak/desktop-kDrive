<UserControl x:Class="Infomaniak.kDrive.CustomControls.ConsentDialog"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls">
    <ContentDialog x:Name="Dialog"
                   PrimaryButtonText="Enregistrer"
                   CloseButtonText="Annuler"
                   DefaultButton="Primary">

        <ContentDialog.TitleTemplate>
            <DataTemplate>
                <local:SvgIcon UriString="{Binding ElementName=Root,Path=LogoUriStr}"
                               MaxWidth="120" />
            </DataTemplate>
        </ContentDialog.TitleTemplate>

        <ContentDialog.Content>
            <StackPanel Spacing="12">
                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"
                           TextAlignment="Justify"
                           Margin="0,0,0,8" />
                <ToggleSwitch x:Name="Toggle"
                              x:Uid="CC_ConsentDialog_Toggle"
                              IsOn="{x:Bind CurrentValue, Mode=OneWay}" />
            </StackPanel>
        </ContentDialog.Content>
    </ContentDialog>
</UserControl>
