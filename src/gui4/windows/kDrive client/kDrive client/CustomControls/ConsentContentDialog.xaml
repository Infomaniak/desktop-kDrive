<UserControl x:Class="Infomaniak.kDrive.CustomControls.ConsentDialog"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Infomaniak.kDrive.CustomControls"
             xmlns:kDrive="using:Infomaniak.kDrive">
    <ContentDialog x:Name="Dialog"
                   PrimaryButtonText="{x:Bind kDrive:Localizer.Instance.GetString('buttonSave')}"
                   CloseButtonText="{x:Bind kDrive:Localizer.Instance.GetString('buttonCancel')}"
                   DefaultButton="Primary">

        <ContentDialog.TitleTemplate>
            <DataTemplate>
                <local:SvgIcon UriString="{Binding ElementName=Root,Path=LogoUriStr}"
                               Height="{StaticResource Infomaniak.Style.Spacing.L}"
                               HorizontalAlignment="Left" />
            </DataTemplate>
        </ContentDialog.TitleTemplate>

        <ContentDialog.Content>
            <StackPanel Spacing="12">
                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"
                           TextAlignment="Justify"
                           Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XXS}" />
                <ToggleSwitch x:Name="Toggle"
                              OnContent="{x:Bind kDrive:Localizer.Instance.GetString('labelAllowTracking')}"
                              OffContent="{x:Bind kDrive:Localizer.Instance.GetString('labelAllowTracking')}"
                              IsOn="{x:Bind CurrentValue, Mode=OneWay}" />
            </StackPanel>
        </ContentDialog.Content>
    </ContentDialog>
</UserControl>
