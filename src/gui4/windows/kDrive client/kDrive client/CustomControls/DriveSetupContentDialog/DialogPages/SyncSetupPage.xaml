<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.DriveSetupContentDialog.SyncSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:controlsErrors="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:templateSelectors="using:Infomaniak.kDrive.TemplateSelectors"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToIntegerConverter x:Key="BooleanToIntegerConverter" />
        <converters:DateTimeToTimeAgoConverter x:Key="DateTimeToTimeAgoConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Page.Resources>

    <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />

            <!-- Drive -->
            <RowDefinition Height="Auto" />

            <!-- Local folder -->
            <RowDefinition Height="Auto" />

            <!-- Exclusion -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Configurer la synchronisation de ce kDrive :"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Drive -->
        <Border Grid.Row="1"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
            <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <controls:SvgIcon Height="16"
                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                  Foreground="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}"
                                  VerticalAlignment="Center" />

                <TextBlock Text="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Name}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind DriveSetupContentDialogVM.NewSyncs, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding"
                            Value="0" />
                    <Setter Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    <Setter Property="Margin"
                            Value="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XXS}" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:NewSync">
                    <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                              RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                              Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <controls:SvgIcon Grid.Column="0"
                                              Grid.Row="0"
                                              Height="16"
                                              UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                              Foreground="{x:Bind Drive.Color, Converter={StaticResource ColorToBrushConverter}}"
                                              VerticalAlignment="Center" />

                            <!-- Drive name -->
                            <TextBlock Grid.Column="1"
                                       Grid.Row="0"
                                       Text="{x:Bind Drive.Name}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center" />

                            <Grid Grid.Column="1"
                                  Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- Local path -->
                                <Grid Grid.Row="0"
                                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Emplacement :"
                                               FontSize="12"
                                               FontWeight="Normal"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind LocalPath, Mode=OneWay}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind LocalPath, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                                    </TextBlock>
                                </Grid>

                                <!-- Exclusions -->
                                <Grid Grid.Row="1"
                                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Contenu synchronisé :"
                                               FontSize="12"
                                               FontWeight="Normal"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Tout le kDrive"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="WordEllipsis" />
                                </Grid>
                            </Grid>
                            <!-- Edit button -->
                            <HyperlinkButton Grid.Column="2"
                                             Grid.RowSpan="2"
                                             Content="Configurer"
                                             Click="EditButton_Click" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </Grid>
</Page>
