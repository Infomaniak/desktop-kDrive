<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.DriveSetupContentDialog.SyncSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:controlsErrors="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:templateSelectors="using:Infomaniak.kDrive.TemplateSelectors"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToIntegerConverter x:Key="BooleanToIntegerConverter" />
        <converters:DateTimeToTimeAgoConverter x:Key="DateTimeToTimeAgoConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Page.Resources>
    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>
    <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />

            <!-- Drive -->
            <RowDefinition Height="Auto" />

            <!-- Local folder -->
            <RowDefinition Height="Auto" />

            <!-- Exclusion -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{x:Bind kDrive:Localizer.Instance.GetString('onBoardingAdvancedSettingsDriveTitle')}"
                   TextWrapping="WrapWholeWords"
                   Style="{StaticResource SubtitleTextBlockStyle}" />

        <!-- Drive -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                HorizontalAlignment="Left">
            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:SvgIcon Grid.Column="0"
                                  Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                  Foreground="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}"
                                  VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Name}"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center">
                <ToolTipService.ToolTip>
                    <ToolTip Content="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Name}" />
                </ToolTipService.ToolTip>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Local folder -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('labelSyncLocation')}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsDriveCustomizeLocation')}"
                               TextWrapping="WrapWholeWords"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ToolTipService.ToolTip>
                        <ToolTip Content="{x:Bind DriveSetupContentDialogVM.CurrentSync.LocalPath, Mode=OneWay}" />
                    </ToolTipService.ToolTip>

                    <!-- Default location dropdown -->
                    <DropDownButton Grid.Row="0"
                                    Grid.Column="0"
                                    Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonDefaultLocation')}"
                                    Visibility="{x:Bind DriveSetupContentDialogVM.CurrentSync.IsDefaultLocalPath,Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                    Click="ChangeFolder_Click" />

                    <!-- Custom location dropdown -->
                    <DropDownButton Grid.Row="0"
                                    Grid.Column="0"
                                    Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonCustomLocation')}"
                                    Visibility="{x:Bind DriveSetupContentDialogVM.CurrentSync.IsDefaultLocalPath,Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True' , Mode=OneWay}"
                                    Click="ChangeFolder_Click" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind DriveSetupContentDialogVM.CurrentSync.LocalPath, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <!--Exclusions -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsDriveExclusionTitle')}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsDriveExclusionDescription')}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Column="0"
                            Grid.Row="0"
                            Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSelectFolders')}"
                            Click="Exclusionbutton_click" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                                Visibility="{x:Bind DriveSetupContentDialogVM.CurrentSync.ExcludedNodeIds.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True' ,Mode=OneWay}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-check-outline}"
                                          Height="12"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingExclusionSummaryNone')}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                                Visibility="{x:Bind DriveSetupContentDialogVM.CurrentSync.ExcludedNodeIds.Count, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-maybe-check}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingExclusionSummaryAtLeastOne')}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   TextTrimming="WordEllipsis">
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.ColumnSpan="2"
                               Grid.Row="1"
                               Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAdvancedSettingsDriveExclusionTip')}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
