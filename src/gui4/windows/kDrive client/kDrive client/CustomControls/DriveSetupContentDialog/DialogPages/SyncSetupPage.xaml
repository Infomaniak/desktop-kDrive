<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.DriveSetupContentDialog.SyncSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:controlsErrors="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:templateSelectors="using:Infomaniak.kDrive.TemplateSelectors"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToIntegerConverter x:Key="BooleanToIntegerConverter" />
        <converters:DateTimeToTimeAgoConverter x:Key="DateTimeToTimeAgoConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </Page.Resources>

    <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />

            <!-- Drive -->
            <RowDefinition Height="Auto" />

            <!-- Local folder -->
            <RowDefinition Height="Auto" />

            <!-- Exclusion -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Configurer la synchronisation de ce kDrive"
                   TextWrapping="WrapWholeWords"
                   Style="{StaticResource SubtitleTextBlockStyle}" />

        <!-- Drive -->
        <Border Grid.Row="1"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}"
                HorizontalAlignment="Left">
            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:SvgIcon Grid.Column="0"
                                  Height="16"
                                  UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                  Foreground="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Color, Converter={StaticResource ColorToBrushConverter}}"
                                  VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind DriveSetupContentDialogVM.CurrentSync.Drive.Name}"
                           Style="{StaticResource BodyLargeTextBlockStyle}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Local folder -->
        <Border Grid.Row="2"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Emplacement"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="Personnalisez l'emplacement du dossier kDrive sur votre ordinateur :"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Column="0"
                            Grid.Row="0"
                            Content="Modifier l'emplacement" 
                            Click="ChangeFolder_Click"/>

                    <TextBlock Grid.Column="1"
                               Grid.Row="0"
                               Text="{x:Bind DriveSetupContentDialogVM.CurrentSync.LocalPath, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                    <TextBlock Grid.ColumnSpan="2"
                               Grid.Row="1"
                               Text="Le dossier choisi doit être vide pour que la synchronisation fonctionne correctement."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <!--Exclusions -->
        <Border Grid.Row="3"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.XS}">
            <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Dossiers synchronisés"
                               Style="{StaticResource BodyTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="Choisissez les dossiers à synchronisés sur cet ordinateur :"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Column="0"
                            Grid.Row="0"
                            Content="Sélectionner des dossiers" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-check-outline}"
                                          Height="12"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center" />

                        <TextBlock Text="Tous les dossiers du kDrive"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Grid.ColumnSpan="2"
                               Grid.Row="1"
                               Text="Les dossiers non sélectionnés resteront accessibles en ligne."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
