<Page x:Class="Infomaniak.kDrive.Pages.Onboarding.NoDrivesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
      xmlns:types="using:Infomaniak.kDrive.Types"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.XXL}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
            <!-- Title -->
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingDriveSelectionTitle')}"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Title}"
                       Foreground="{ThemeResource TextFillColorPrimary}" />

            <!-- User info -->
            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                        Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XXS}"
                        CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                        HorizontalAlignment="Left">
                    <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}"
                          Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.XS}"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <PersonPicture Grid.Column="0"
                                       ProfilePicture="{x:Bind OnboardingViewModel.SelectedUser.GetAvatarImageSource(48), Mode=OneWay}"
                                       HorizontalAlignment="Left"
                                       Height="24"
                                       Width="24" />

                        <TextBlock Grid.Column="1"
                                   MaxWidth="200"
                                   Text="{x:Bind OnboardingViewModel.SelectedUser.Name}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondary}" />
                    </Grid>
                </Border>

                <HyperlinkButton Grid.Column="1"
                                 Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonChangeUser')}"
                                 HorizontalAlignment="Left"
                                 Click="ChangeUserButton_Click" />

            </Grid>
        </StackPanel>

        <!-- No drive available -->
        <StackPanel Grid.Row="1"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <!-- Subtitle -->
            <TextBlock Grid.Row="0"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingDriveSelectionNoDriveTitle')}"
                       Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}" />

            <!-- No drive text -->
            <TextBlock Grid.Row="1"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingDriveSelectionNoDriveDescription')}"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       TextWrapping="WrapWholeWords" />
        </StackPanel>

        <!-- Offers Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Top.S}">

            <HyperlinkButton Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonShowOffers')}"
                             HorizontalAlignment="Left"
                             Click="OnOffersButtonClick" />

            <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonStartForFree')}"
                    HorizontalAlignment="Left"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnStartFreeButtonClick" />
        </StackPanel>
    </Grid>
</Page>
