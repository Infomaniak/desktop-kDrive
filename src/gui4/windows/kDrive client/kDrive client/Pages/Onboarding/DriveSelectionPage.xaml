<Page x:Class="Infomaniak.kDrive.Pages.Onboarding.DriveSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.Pages.Onboarding"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
      xmlns:types="using:Infomaniak.kDrive.Types"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <Page.Resources>
        <!-- Converters -->
        <converters:BooleanToInvertedBooleanConverter  x:Key="BooleanToInvertedBooleanConverter" />
        <converters:IntegerToBooleanConverter  x:Key="IntegerToBooleanConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />

        <!-- Data templates -->
        <DataTemplate x:Key="SingleAccountDriveTemplate"
                      x:DataType="types:IDrive">
            <Border Style="{StaticResource Infomaniak.Style.Border.WithContent}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    MinHeight="44"
                    MinWidth="280"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}">
                <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <CheckBox Checked="DriveListCheckBox_Checked"
                              Unchecked="DriveListCheckBox_Unchecked"
                              HorizontalAlignment="Stretch"
                              MinWidth="0"
                              MinHeight="0" />

                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                      Foreground="{x:Bind Color, Converter={StaticResource ColorToBrushConverter}}"
                                      Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />
                    <TextBlock  Text="{x:Bind Name}"
                                Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SingleAccountDriveDisabledTemplate"
                      x:DataType="types:IDrive">
            <Border Style="{StaticResource Infomaniak.Style.Border.WithContent}"
                    Background="{ThemeResource ButtonDisabledBackgroundThemeBrush}"
                    MinHeight="44"
                    MinWidth="280"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}">
                <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <CheckBox IsChecked="True"
                              HorizontalAlignment="Stretch"
                              MinWidth="0"
                              MinHeight="0"
                              IsEnabled="False" />

                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                      Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                      Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />
                    <TextBlock  Text="{x:Bind Name}"
                                Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MultiAccountDriveTemplate"
                      x:DataType="types:IDrive">
            <Border Style="{StaticResource Infomaniak.Style.Border.WithContent}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    MinHeight="44"
                    MinWidth="280"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Orientation="Horizontal">
                        <CheckBox Checked="DriveListCheckBox_Checked"
                                  Unchecked="DriveListCheckBox_Unchecked"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="0"
                                  MinHeight="0" />

                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                          Foreground="{x:Bind Color, Converter={StaticResource ColorToBrushConverter}}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Grid.Row="0"
                               Text="{x:Bind Name}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Grid.Row="1"
                               Text="{x:Bind AccountName}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                               Foreground="{ThemeResource TextFillColorSecondary}" />
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MultiAccountDriveDisabledTemplate"
                      x:DataType="types:IDrive">
            <Border Style="{StaticResource Infomaniak.Style.Border.WithContent}"
                    Background="{ThemeResource ButtonDisabledBackgroundThemeBrush}"
                    MinHeight="44"
                    MinWidth="280"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}">
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Orientation="Horizontal">
                        <CheckBox IsChecked="True"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="0"
                                  MinHeight="0"
                                  IsEnabled="False" />

                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                          Style="{StaticResource Infomaniak.Style.Icon.Size.S}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Grid.Row="0"
                               Text="{x:Bind Name}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Grid.Row="1"
                               Text="{x:Bind AccountName}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                </Grid>
            </Border>
        </DataTemplate>
        <local:DriveTemplateSelector x:Key="DriveTemplateSelector"
                                     SingleAccountDriveTemplate="{StaticResource SingleAccountDriveTemplate}"
                                     MultiAccountDriveTemplate="{StaticResource MultiAccountDriveTemplate}"
                                     SingleAccountDriveDisabledTemplate="{StaticResource SingleAccountDriveDisabledTemplate}"
                                     MultiAccountDriveDisabledTemplate="{StaticResource MultiAccountDriveDisabledTemplate}" />
    </Page.Resources>

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.XXL}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.XL}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                <!-- Title -->
                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingDriveSelectionTitle')}"
                           Style="{StaticResource Infomaniak.Style.TextBlock.Title}"
                           Foreground="{ThemeResource TextFillColorPrimary}" />

                <!-- User info -->
                <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                            Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XXS}"
                            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                            HorizontalAlignment="Left">
                        <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.S}"
                              Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.XS}"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <PersonPicture Grid.Column="0"
                                           ProfilePicture="{x:Bind ObViewModel.SelectedUser.GetAvatarImageSource(48), Mode=OneWay}"
                                           HorizontalAlignment="Left"
                                           Height="24"
                                           Width="24" />

                            <TextBlock Grid.Column="1"
                                       MaxWidth="200"
                                       Text="{x:Bind ObViewModel.SelectedUser.Name}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondary}" />
                        </Grid>
                    </Border>

                    <HyperlinkButton Grid.Column="1"
                                     Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonChangeUser')}"
                                     HorizontalAlignment="Left"
                                     Click="ChangeUserButton_Click" />

                </Grid>
            </StackPanel>

            <!-- Drive available -->
            <Grid Grid.Row="1"
                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Subtitle -->
                <TextBlock Grid.Row="0"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingDriveSelectionSelectTitle')}"
                           Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}" />

                <!-- List of drives -->
                <ListView x:Name="DriveList"
                          Grid.Row="1"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ItemsSource="{x:Bind ObViewModel.SelectedUser.AllDrives, Mode=OneWay}"
                          HorizontalAlignment="Left">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"
                                    Value="{StaticResource Infomaniak.Style.Thickness.Right.M}" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <!-- Data templates -->
                        <DataTemplate x:DataType="types:IDrive">
                            <Grid>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind kDrive:Localizer.Instance.GetString('onboardingAlreadySyncedDriveTooltip')}"
                                             VerticalOffset="-80"
                                             IsEnabled="{x:Bind IsConfigured, Mode=OneWay}" />
                                </ToolTipService.ToolTip>

                                <ContentControl Content="{x:Bind}"
                                                ContentTemplateSelector="{StaticResource DriveTemplateSelector}"
                                                VerticalContentAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- Continue button -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">

            <HyperlinkButton x:Name="AdvancedButton"
                             Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonAdvancedParameters')}"
                             HorizontalAlignment="Left"
                             IsEnabled="{x:Bind ObViewModel.NewSyncs.Count, Converter={StaticResource IntegerToBooleanConverter}, Mode=OneWay}"
                             Click="AdvancedSettingsButton_Click" />

            <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonValidate')}"
                    HorizontalAlignment="Left"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ObViewModel.NewSyncs.Count, Converter={StaticResource IntegerToBooleanConverter}, Mode=OneWay}"
                    Click="Finish_Click" />

        </StackPanel>
    </Grid>
</Page>
