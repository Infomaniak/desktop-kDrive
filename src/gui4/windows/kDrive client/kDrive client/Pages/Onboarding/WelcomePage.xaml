<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Onboarding.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.65*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XL}">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                <!-- Titre -->
                <TextBlock x:Name="Title"
                           Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingLoginTitle')}"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorPrimary}" />

                <!-- Sous-titre -->
                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingLoginDescription')}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           MaxWidth="345" />

            </StackPanel>
            <!-- Boutons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <HyperlinkButton Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonCreateAccount')}"
                                 Click="SignupButton_Click" />

                <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonLogin')}"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="120"
                        Click="SigninButton_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
