<Page x:Class="Infomaniak.kDrive.Pages.StoragePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter  x:Key="BooleanToVisibilityConverter" />
        <converters:BytesToHumanReadableStringConverter x:Key="BytesToHumanReadableStringConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />
            <!-- Main -->
            <RowDefinition Height="Auto" />
            <!-- Manage storage -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('tabTitleStorage')}"
                   Grid.Row="0"
                   Style="{StaticResource Infomaniak.Style.TextBlock.Title}" />

        <!-- Main - Missing disk -->
        <Grid  Grid.Row="1"
               Visibility="{x:Bind PageViewModel.IsDiskConnected, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True'}"
               RowSpacing="{StaticResource Infomaniak.Style.Spacing.XL}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <controls:SvgIcon Grid.Row="0"
                              Width="120"
                              UriString="{StaticResource Infomaniak.Custom.Images.hardware}" />
            <StackPanel Grid.Row="1"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.M}">
                <TextBlock Text="{x:Bind PageViewModel.MissingDiskTitle, Mode=OneWay}"
                           TextAlignment="Center"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind PageViewModel.MissingDiskSubtitle, Mode=OneWay}"
                           TextAlignment="Center" />
                <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonRetry')}"
                        HorizontalAlignment="Center"
                        Style="{ThemeResource TextBlockButtonStyle}"
                        Click="RetryButton_click" />
                <ProgressRing x:Name="RetryProgressRing"
                              Width="16"
                              Height="16"
                              HorizontalAlignment="Center"
                              Visibility="Collapsed" />
            </StackPanel>
        </Grid>
        <!-- Main -->
        <Grid Grid.Row="1"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
              RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
              Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.M}"
              Visibility="{x:Bind PageViewModel.IsDiskConnected, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                    <ToolTipService.ToolTip>
                        <ToolTip>
                            <TextBlock Text="{x:Bind PageViewModel.DiskRoot, Mode=OneWay}" />
                        </ToolTip>
                    </ToolTipService.ToolTip>
                    <TextBlock Style="{StaticResource Infomaniak.Style.TextBlock.Subtitle}"
                               Text="{x:Bind GetThisComputerTitle(PageViewModel.DiskRoot, PageViewModel.DiskSize), Mode=OneWay}" />

                    <ProgressRing Height="8"
                                  Width="8"
                                  Visibility="{x:Bind PageViewModel.Loading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <controls:MultiValueProgressBar Value1="{x:Bind PageViewModel.HydratedFileSize, Mode=OneWay}"
                                                Value2="{x:Bind PageViewModel.OtherFileSize, Mode=OneWay}"
                                                Value3="{x:Bind PageViewModel.DiskFreeSize, Mode=OneWay}"
                                                Color1="{ThemeResource AccentAAFillColorDefaultBrush }"
                                                Color2="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                Color3="{ThemeResource AccentAAFillColorDisabledBrush}" />
                <Grid>
                    
                    <TextBlock Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                               Foreground="{ThemeResource TextFillColorSecondary}"
                               Text="{x:Bind GetStorageUsedLabel(PageViewModel.DiskUsedSize), Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                               Foreground="{ThemeResource TextFillColorSecondary}"
                               Text="{x:Bind GetStorageFreeLabel(PageViewModel.DiskFreeSize), Mode=OneWay}" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Row="1">
                <!-- Hydrated files -->
                <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             Height="8"
                             Width="8"
                             Fill="{ThemeResource AccentAAFillColorDefaultBrush}" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('storageComputerUsedByKDrive')}"
                               Grid.Column="1"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind PageViewModel.HydratedFileSize, Mode=OneWay, Converter={StaticResource BytesToHumanReadableStringConverter}}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind PageViewModel.HydratedFileSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True'}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                                Visibility="{x:Bind PageViewModel.HydratedFileSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}}">
                        <ProgressRing Height="8"
                                      Width="8" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelStorageLoading')}"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                </Grid>

                <Rectangle Height="1"
                           Fill="LightGray"
                           HorizontalAlignment="Stretch" />

                <!-- Other files -->
                <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             Height="8"
                             Width="8"
                             Fill="{ThemeResource SystemFillColorSuccessBackgroundBrush}" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('storageComputerUsedByOther')}"
                               Grid.Column="1"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind PageViewModel.OtherFileSize, Mode=OneWay, Converter={StaticResource BytesToHumanReadableStringConverter}}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind PageViewModel.OtherFileSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True'}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                                Visibility="{x:Bind PageViewModel.OtherFileSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}}">
                        <ProgressRing Height="8"
                                      Width="8" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelStorageLoading')}"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                </Grid>
                <Rectangle Height="1"
                           Fill="LightGray"
                           HorizontalAlignment="Stretch" />

                <!-- Free spaces files -->
                <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.S}"
                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             Height="8"
                             Width="8"
                             Fill="{ThemeResource AccentAAFillColorDisabledBrush}" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('storageComputerFreeSpace')}"
                               Grid.Column="1"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind PageViewModel.DiskFreeSize, Mode=OneWay, Converter={StaticResource BytesToHumanReadableStringConverter}}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind PageViewModel.DiskFreeSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True'}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                                Visibility="{x:Bind PageViewModel.DiskFreeSize, Mode=OneWay, Converter={StaticResource IsNullToBoolOrVisibilityConverter}}">
                        <ProgressRing Height="8"
                                      Width="8" />

                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelStorageLoading')}"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.BodySb}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                </Grid>
            </StackPanel>
        </Grid>
        <Border Grid.Row="2"
                Height="96"
                Background="LightGray"
                CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.M}"
                Visibility="Collapsed">
        </Border>
    </Grid>
</Page>
