<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Errors.ResolveManyConflictPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:errors="using:Infomaniak.kDrive.CustomControls.Errors"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:kDrive="using:Infomaniak.kDrive"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:FilePathToIconConverter x:Key="FilePathToIconConverter" />
    </Page.Resources>
    <Grid Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.XS}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              Height="{StaticResource Infomaniak.Style.Spacing.XL}"
              Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.S}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('conflictErrorTitle')}"
                       FontSize="{StaticResource TitleTextBlockFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Bottom"
                       PointerPressed="BreadcrumbConflict_Click" />

            <FontIcon Grid.Column="1"
                      Glyph="&#xE76C;"
                      Width="24"
                      FontSize="14"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}"
                      VerticalAlignment="Bottom" />

            <TextBlock Grid.Column="2"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('titleConflictIndividualResolution')}"
                       FontSize="{StaticResource TitleTextBlockFontSize}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Bottom" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.M}">
            <TextBlock FontWeight="SemiBold"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString1i('labelManyConflictTitle', _errorPageVM.ConflictsCount), Mode=OneWay}" />

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind kDrive:Localizer.Instance.GetString('labelChooseConflictVersion'), Mode=OneWay}" />
        </StackPanel>

        <Grid  Grid.Row="2"
               Padding="0"
               RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}"
               ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XL}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <AutoSuggestBox Grid.Row="0"
                            Grid.Column="0"
                            PlaceholderText="{x:Bind kDrive:Localizer.Instance.GetString('conflictsSearchBoxPlaceholder')}"
                            Text="{x:Bind _errorPageVM.ConflictFilterText, Mode=TwoWay}"
                            QueryIcon="Find"
                            IsSuggestionListOpen="False"
                            HorizontalAlignment="Left"
                            MinWidth="180" />

            <Button Grid.Row="0"
                    Grid.Column="1"
                    Style="{ThemeResource AccentButtonStyle}"
                    Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonStartConflictsResolution')}"
                    Click="ResolveManyConflictButton_Click" />

            <ListView Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      ItemsSource="{x:Bind _errorPageVM.FilteredConflictErrors, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      BorderThickness="0"
                      VerticalAlignment="Top">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:Error">
                        <Border Background="{ThemeResource LayerFillColorDefault}"
                                Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.XS}"
                                VerticalAlignment="Stretch"
                                BorderThickness="1"
                                CornerRadius="1"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <Grid ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                                  Margin="{StaticResource Infomaniak.Style.Thickness.Left.XS}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <controls:SvgIcon Grid.Column="0"
                                                  UriString="{x:Bind Path, Converter={StaticResource FilePathToIconConverter}}"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource Infomaniak.Style.Icon.Size.XS}" />

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="{x:Bind Path, Mode=OneWay}">
                                    <ToolTipService.ToolTip>
                                        <TextBlock Text="{x:Bind DestinationPath, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                                <Button Grid.Column="2"
                                        Content="{x:Bind kDrive:Localizer.Instance.GetString('conflictErrorAction')}"
                                        Margin="{StaticResource Infomaniak.Style.Thickness.Right.S}"
                                        Click="ResolveOneConflictButton_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Stretch" />
                    </Style>

                </ListView.ItemContainerStyle>
            </ListView>
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        VerticalAlignment="Center"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.S}"
                        Visibility="{x:Bind _errorPageVM.FilteredConflictErrors.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=true', Mode=OneWay}">
                <controls:SvgIcon Height="120"
                                  UriString="{ThemeResource Infomaniak.Custom.Images.servin}" />
                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelNoConflictsFound')}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
