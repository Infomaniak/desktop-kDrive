<Page x:Class="Infomaniak.kDrive.Pages.Settings.TemplateExclusionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:settings="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      xmlns:popupPages="using:Infomaniak.kDrive.Pages.Popup"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />
            <!-- Drive management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Vertical"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('settingsTitle')}"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>

        <!-- Template exclusion management -->
        <ScrollView Grid.Row="1">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('filesToExclude')}"
                           Style="{StaticResource TitleTextBlockStyle}" />

                <!-- Default Exclusion -->
                <toolKit:SettingsExpander Header="{x:Bind kDrive:Localizer.Instance.GetString('defaultExclusionFileListHeader')}"
                                          Description="{x:Bind kDrive:Localizer.Instance.GetString('defaultExclusionFileListDescription')}">
                    <toolKit:SettingsExpander.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-circle-cross}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    </toolKit:SettingsExpander.HeaderIcon>
                    <toolKit:SettingsExpander.Items>
                        <toolKit:SettingsCard ContentAlignment="Left">
                            <ListView ItemsSource="{x:Bind _templateListModel.DefaultTemplates, Mode=OneWay}"
                                      HorizontalAlignment="Stretch"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="MinHeight"
                                                Value="20" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ExclusionTemplate">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-text}"
                                                              Style="{StaticResource Infomaniak.Style.Icon.Size.XXS}"
                                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Text="{x:Bind Template, Mode=OneWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </toolKit:SettingsCard>
                    </toolKit:SettingsExpander.Items>
                </toolKit:SettingsExpander>

                <!-- User Exclusion -->
                <!-- User Exclusion - No template-->
                <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('userExclusionFileListHeader')}"
                                      Description="{x:Bind kDrive:Localizer.Instance.GetString('userExclusionFileListDescription')}"
                                      Visibility="{x:Bind _templateListModel.UserDefinedTemplates.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                    <toolKit:SettingsCard.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-circle-plus}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    </toolKit:SettingsCard.HeaderIcon>
                    <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonAddFileExclusionRule')}"
                            Click="AddRuleButton_Click" />
                </toolKit:SettingsCard>

                <!-- User Exclusion - At least one template-->
                <toolKit:SettingsExpander Header="{x:Bind kDrive:Localizer.Instance.GetString('userExclusionFileListHeader')}"
                                          Description="{x:Bind kDrive:Localizer.Instance.GetString('userExclusionFileListDescription')}"
                                          Visibility="{x:Bind _templateListModel.UserDefinedTemplates.Count, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">

                    <toolKit:SettingsExpander.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-circle-plus}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    </toolKit:SettingsExpander.HeaderIcon>
                    <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonAddFileExclusionRule')}"
                            Click="AddRuleButton_Click" />
                    <toolKit:SettingsExpander.Items>
                        <toolKit:SettingsCard HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              ContentAlignment="Vertical">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0"
                                      HorizontalAlignment="Stretch"
                                      ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              x:Name="SelectAllCheckBox"
                                              Content="{x:Bind kDrive:Localizer.Instance.GetString('labelRules')}"
                                              HorizontalAlignment="Stretch"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Click="SelectAllCheckBox_Click" />

                                    <TextBlock  Grid.Column="1"
                                                Text="{x:Bind kDrive:Localizer.Instance.GetString('labelNotifications')}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                                <ListView Grid.Row="1"
                                          x:Name="UserTemplatesListView"
                                          ItemsSource="{x:Bind _templateListModel.UserDefinedTemplates, Mode=OneWay}"
                                          HorizontalAlignment="Stretch"
                                          SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:ExclusionTemplate">
                                            <Grid HorizontalAlignment="Stretch"
                                                  ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Content="{x:Bind Template, Mode=OneWay}"
                                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          Click="TemplateCheckBox_Click" />

                                                <ToggleSwitch Grid.Column="2"
                                                              OnContent="{x:Bind kDrive:Localizer.Instance.GetString('labelActivated')}"
                                                              OffContent="{x:Bind kDrive:Localizer.Instance.GetString('labelDeactivated')}"
                                                              IsOn="{x:Bind Warning, Mode=OneWay}"
                                                              Toggled="WarningToggleSwitch_Toggled"
                                                              HorizontalAlignment="Right">
                                                    <ToolTipService.ToolTip>
                                                        <ToolTip Content="{x:Bind kDrive:Localizer.Instance.GetString('tooltipExclusionRuleNotifications')}" />
                                                    </ToolTipService.ToolTip>
                                                </ToggleSwitch>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <HyperlinkButton Grid.Row="2"
                                                 x:Name="DeleteButton"
                                                 Content="{x:Bind kDrive:Localizer.Instance.GetStringWithPlural1i('winbuttonRemoveFileExclusionRule', _templateListModel.SelectedCount, _templateListModel.SelectedCount), Mode=OneWay}"
                                                 Foreground="{ThemeResource SystemErrorTextColor}"
                                                 Visibility="{x:Bind _templateListModel.HasSelectedTemplates, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Click="DeleteButton_Click" />
                            </Grid>
                        </toolKit:SettingsCard>
                    </toolKit:SettingsExpander.Items>
                </toolKit:SettingsExpander>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
