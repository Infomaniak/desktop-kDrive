<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Settings.TemplateExclusionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:settings="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />

    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />
            <!-- Drive management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Vertical"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock x:Uid="Page_SettingsPage_Title"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Title}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>

        <!-- Drive management -->
        <ScrollView Grid.Row="1">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <!-- Main sync is setted -->
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                            Visibility="{x:Bind ManagedDrive.MainSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.Custom.Icons.drive-custom}"
                                          Foreground="{x:Bind ManagedDrive.Color, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" />
                        <TextBlock Text="{x:Bind ManagedDrive.Name, Mode=OneWay}"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                    </StackPanel>

                    <!-- Location -->
                    <toolKit:SettingsCard x:Uid="Page_Settings_DriveManagementPage_Location">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-open}"
                                              Height="20"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <HyperlinkButton Content="{x:Bind ManagedDrive.MainSync.LocalPath, Mode=OneWay}"
                                         Click="LocationHyperLinkButton_Clicked" />
                    </toolKit:SettingsCard>

                    <!-- Folder Selection -->
                    <toolKit:SettingsExpander x:Uid="Page_Settings_DriveManagementPage_FolderSelection">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-loop}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <!-- Presentation -->
                            <Grid Padding="{StaticResource SettingsCardPadding}"
                                  Background="{ThemeResource LayerFillColorDefault}"
                                  RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0"
                                            Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                    <TextBlock x:Uid="Page_Settings_DriveManagementPage_FolderSelection_Presentation_Header"
                                               Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                               TextWrapping="Wrap" />

                                    <TextBlock x:Uid="Page_Settings_DriveManagementPage_FolderSelection_Presentation_Description"
                                               Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <controls:SyncExclusionSelector x:Name="ExclSelector"
                                                                Grid.Row="1"
                                                                DriveId="{x:Bind ManagedDrive.DriveId, Mode=OneWay}"
                                                                UserDbId="{x:Bind ManagedDrive.Account.User.DbId}"
                                                                SyncDbId="{x:Bind ManagedDrive.MainSync.DbId, Mode=OneWay}"
                                                                HorizontalAlignment="Stretch" />
                            </Grid>
                            <toolKit:SettingsCard Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind ExclSelector.HasPendingChanges, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                                    <Button x:Uid="Page_Settings_DriveManagementPage_FolderSelection_CancelButton"
                                            Click="CancelSyncSelection_click"
                                            IsEnabled="{x:Bind ExclSelector.IsLoading, Converter={StaticResource BooleanToInvertedBooleanConverter} , Mode=OneWay}" />
                                    <Button x:Uid="Page_Settings_DriveManagementPage_FolderSelection_SaveButton"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="SaveSyncSelection_click"
                                            IsEnabled="{x:Bind ExclSelector.IsLoading, Converter={StaticResource BooleanToInvertedBooleanConverter} , Mode=OneWay}" />
                                </StackPanel>
                            </toolKit:SettingsCard>
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>

                    <!-- Lite Sync -->
                    <toolKit:SettingsExpander x:Name="SyncTypeExpander"
                                              x:Uid="Page_Settings_DriveManagementPage_SyncMode"
                                              Visibility="{x:Bind ManagedDrive.MainSync.SupportOnlineMode, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Essentials.cog}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                              Height="32" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <toolKit:SettingsCard Background="{ThemeResource LayerFillColorDefault}"
                                                  ContentAlignment="Left"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="10000" />
                                        <!-- Make the entire card clickable to select the radio button -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Card content -->
                                    <toolKit:SettingsCard Grid.Column="1"
                                                          x:Uid="Page_Settings_DriveManagementPage_SyncMode_Online"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0" />

                                    <!-- RadioButton -->
                                    <RadioButton x:Name="OnlineRadioButton"
                                                 Grid.ColumnSpan="2"
                                                 GroupName="SyncModeRadioGroup"
                                                 MinWidth="0"
                                                 HorizontalAlignment="Stretch"
                                                 IsChecked="{x:Bind ManagedDrive.MainSync.IsTypeOnline, Mode=OneWay}"
                                                 Checked="LiteSyncRadioButtonChecked"
                                                 Unchecked="LiteSyncRadioButtonUnchecked"
                                                 IsEnabled="False" />
                                </Grid>
                            </toolKit:SettingsCard>

                            <toolKit:SettingsCard Background="{ThemeResource LayerFillColorDefault}"
                                                  ContentAlignment="Left"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="10000" />
                                        <!-- Make the entire card clickable to select the radio button -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Card content -->
                                    <toolKit:SettingsCard Grid.Column="1"
                                                          x:Uid="Page_Settings_DriveManagementPage_SyncMode_Offline"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0" />

                                    <!-- RadioButton -->
                                    <RadioButton x:Name="OfflineRadioButton"
                                                 Grid.ColumnSpan="2"
                                                 GroupName="SyncModeRadioGroup"
                                                 MinWidth="0"
                                                 IsChecked="{x:Bind ManagedDrive.MainSync.IsTypeOnline, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                                 HorizontalAlignment="Stretch"
                                                 IsEnabled="False" />
                                </Grid>
                            </toolKit:SettingsCard>

                            <toolKit:SettingsCard x:Uid="Page_Settings_DriveManagementPage_SyncMode_InProgress"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            </toolKit:SettingsCard>

                        </toolKit:SettingsExpander.Items>
                        <ProgressRing IsActive="True"
                                      Height="16"
                                      Width="16"
                                      Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                    </toolKit:SettingsExpander>

                    <!-- Remove sync -->
                    <toolKit:SettingsCard Header="Supprimer la synchronisation"
                                          IsClickEnabled="True"
                                          Foreground="{ThemeResource SystemErrorTextColor}"
                                          PointerExited="FixForegroundOnPointerExited"
                                          Click="RemoveSyncSettingsCard_Click">
                    </toolKit:SettingsCard>
                </StackPanel>

                <!-- Main sync is not setted -->
                <!-- TODO: Replace with localization once U/UX design is ready-->
                <toolKit:SettingsCard Header="Configurer la synchronisation principale"
                                      Visibility="{x:Bind ManagedDrive.MainSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, Mode=OneWay}"
                                      IsClickEnabled="True"
                                      IsEnabled="False">
                    <toolKit:SettingsCard.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-circle-plus}"
                                          Height="20"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </toolKit:SettingsCard.HeaderIcon>
                </toolKit:SettingsCard>

                <!-- Advanced syncs -->
                <toolKit:SettingsCard x:Uid="Page_Settings_DriveManagementPage_AdvancedSyncs"
                                      IsClickEnabled="True"
                                      IsEnabled="False">
                    <toolKit:SettingsCard.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-connect}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </toolKit:SettingsCard.HeaderIcon>
                </toolKit:SettingsCard>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
