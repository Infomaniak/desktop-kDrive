<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Settings.TemplateExclusionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:settings="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />

    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />
            <!-- Drive management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Vertical"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock x:Uid="Page_SettingsPage_Title"
                       Style="{StaticResource TitleLargeTextBlockStyle}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>

        <!-- Template exclusion management -->
        <ScrollView Grid.Row="1">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <TextBlock Text="Fichiers à exclure"
                           Style="{StaticResource TitleTextBlockStyle}" />

                <!-- Default Exclusion -->
                <toolKit:SettingsExpander x:Uid="Page_Settings_ExclusionManagementPage_DefaultExclusion">
                    <toolKit:SettingsExpander.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-circle-cross}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    </toolKit:SettingsExpander.HeaderIcon>
                    <toolKit:SettingsExpander.Items>
                        <toolKit:SettingsCard ContentAlignment="Left">
                            <ListView ItemsSource="{x:Bind _templateList.DefaultTemplates, Mode=OneWay}"
                                      HorizontalAlignment="Stretch"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="MinHeight"
                                                Value="20" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ExclusionTemplate">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-text}"
                                                              Height="12"
                                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Text="{x:Bind Template, Mode=OneWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </toolKit:SettingsCard>
                    </toolKit:SettingsExpander.Items>
                </toolKit:SettingsExpander>

                <!-- User Exclusion -->
                <toolKit:SettingsExpander x:Uid="Page_Settings_ExclusionManagementPage_UserExclusion">
                    <toolKit:SettingsExpander.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-circle-plus}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    </toolKit:SettingsExpander.HeaderIcon>
                    <Grid>
                        <Button x:Uid="Page_Settings_ExclusionManagementPage_UserExclusion_AddButton"
                                Click="AddRuleButton_Click" />
                        <ContentDialog x:Name="AddTemplateContentDialog"
                                       x:Uid="Page_Settings_ExclusionManagementPage_UserExclusion_AddContentDialog"
                                       DefaultButton="Primary">
                            <TextBox x:Name="NewTemplateTextBox"
                                     PlaceholderText="*.log" />

                        </ContentDialog>
                    </Grid>
                    <toolKit:SettingsExpander.Items>
                        <toolKit:SettingsCard HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              ContentAlignment="Vertical">
                            <ListView ItemsSource="{x:Bind _templateList.UserDefinedTemplates, Mode=OneWay}"
                                      HorizontalAlignment="Stretch"
                                      SelectionMode="None"
                                      Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:ExclusionTemplate">
                                        <Grid HorizontalAlignment="Stretch"
                                              ColumnSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem x:Uid="Page_Settings_ExclusionManagementPage_UserExclusion_DeleteMenuFlyout"
                                                                    Click="TemplateDeleteMenuItem_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <controls:SvgIcon Grid.Column="0"
                                                              UriString="{StaticResource Infomaniak.DS.Icons.Documents.file-text}"
                                                              Height="12"
                                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Text="{x:Bind Template, Mode=OneWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </toolKit:SettingsCard>
                    </toolKit:SettingsExpander.Items>
                </toolKit:SettingsExpander>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
