<Page x:Class="Infomaniak.kDrive.Pages.Settings.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      xmlns:local="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:viewmodel="using:Infomaniak.kDrive.ViewModels"
      xmlns:types="using:Infomaniak.kDrive.Types"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">
    <Page.Resources>
        <!-- Converters -->
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:ToStringConverter x:Key="ToStringConverter" />
        <!-- DataTemplates -->
        <DataTemplate x:Key="ConfiguredDriveTemplate"
                      x:DataType="types:IDrive">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('syncedDrive')}"
                       VerticalAlignment="Center"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                       Foreground="{ThemeResource TextFillColorSecondary}" />
        </DataTemplate>
        <DataTemplate x:Key="UnconfiguredDriveTemplate"
                      x:DataType="types:IDrive">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('notSyncedDrive'), Mode=OneWay}"
                       VerticalAlignment="Center"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                       Foreground="{ThemeResource TextFillColorSecondary}" />
        </DataTemplate>
        <local:DriveDataTemplateSelector x:Key="DriveDataTemplateSelector"
                                         ConfiguredTemplate="{StaticResource ConfiguredDriveTemplate}"
                                         UnconfiguredTemplate="{StaticResource UnconfiguredDriveTemplate}" />
    </Page.Resources>
    <Grid Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />
            <!-- Main -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="{x:Bind kDrive:Localizer.Instance.GetString('settingsTitle'), Mode=OneWay}"
                   Style="{StaticResource Infomaniak.Style.TextBlock.Title}" />
        <ScrollView Grid.Row="1">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.L}">
                <!-- General -->
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('sidebarItemGeneral'), Mode=OneWay}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Subtitle}" />
                    <!-- General - Update -->
                    <controls:UpdateExpander Visibility="{x:Bind ViewModel.Settings.UpdateManager.UpdateEnabled, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                    <!-- General - Language -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('languageSetting'), Mode=OneWay}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Communication.translate}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <toolKit:SettingsCard.Description>
                            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('languageSettingWarning'), Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.Settings.RestartRequiredForLanguageChange, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                        </toolKit:SettingsCard.Description>
                        <ComboBox SelectedValuePath="Tag"
                                  SelectedValue="{x:Bind ViewModel.Settings.Language, Converter={StaticResource ToStringConverter}, Mode=OneWay}"
                                  SelectionChanged="LanguageComboBox_Changed">
                            <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('labelSameAsSystem'), Mode=OneWay}"
                                          Tag="SystemDefault" />
                            <ComboBoxItem Content="Français"
                                          Tag="FR" />
                            <ComboBoxItem Content="English"
                                          Tag="EN" />
                            <ComboBoxItem Content="Deutsch"
                                          Tag="DE" />
                            <ComboBoxItem Content="Español"
                                          Tag="ES" />
                            <ComboBoxItem Content="Italiano"
                                          Tag="IT" />
                        </ComboBox>
                    </toolKit:SettingsCard>
                    <!-- General - Auto start -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('openKDriveAtStartupSetting'), Mode=OneWay}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.power}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.Settings.AutoStart, Mode=OneWay}"
                                      Toggled="AutoStartToggleSwitch_Toggled" />
                    </toolKit:SettingsCard>
                    <!-- General - Notifications -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('disableNotificationsSetting'), Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.Settings.ShowNotificationsSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Essentials.bell}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <Grid>
                            <ComboBox SelectedValuePath="Tag"
                                      SelectedValue="{x:Bind ViewModel.Settings.NotificationsDisabled, Converter={StaticResource ToStringConverter}, Mode=OneWay}"
                                      SelectionChanged="NotificationsCombobox_SelectionChanged"
                                      Visibility="{x:Bind ViewModel.Settings.NotificationsAuthorizedInSystemSettings, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                      x:Name="NotificationsComboBox">
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('notificationsDisabledNever'), Mode=OneWay}"
                                              Tag="Never" />
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('notificationsDisabledAlways'), Mode=OneWay}"
                                              Tag="Always" />
                                <!-- These options are disabled until the notification snooze feature is fixed (see card 1172-Fix NotificationsDisabled ) -->
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('forOneHour'), Mode=OneWay}"
                                              Tag="OneHour"
                                              IsEnabled="False" />
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('untilTomorrow'), Mode=OneWay}"
                                              Tag="UntilTomorrow"
                                              IsEnabled="False" />
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('forThreeDays'), Mode=OneWay}"
                                              Tag="ThreeDays"
                                              IsEnabled="False" />
                                <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('forOneWeek'), Mode=OneWay}"
                                              Tag="OneWeek"
                                              IsEnabled="False" />
                            </ComboBox>
                            <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonEnableInSettings'), Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.Settings.NotificationsAuthorizedInSystemSettings, Converter={StaticResource BooleanToVisibilityConverter},ConverterParameter='Inverted=True', Mode=OneWay}"
                                    Click="ActivateNotificationInSystem_Button" />
                        </Grid>
                    </toolKit:SettingsCard>
                    <!-- General - MoveToTrash -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('moveDeletedFilesToRecycleBinSetting'), Mode=OneWay}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.trashbin}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="MoveToTrashToggleSwitch"
                                      IsOn="{x:Bind ViewModel.Settings.MoveToTrash, Mode=OneWay}"
                                      Toggled="MoveToTrashToggleSwitch_Toggled" />
                        <toolKit:SettingsCard.Description>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsOn, ElementName=MoveToTrashToggleSwitch, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('moveDeletedFilesToRecycleBinWarning'), Mode=OneWay}"
                                           TextWrapping="WrapWholeWords" />
                                <HyperlinkButton Content="{x:Bind kDrive:Localizer.Instance.GetString('learnMore'), Mode=OneWay}"
                                                 NavigateUri="https://faq.infomaniak.com/2383#desktop" />
                            </StackPanel>
                        </toolKit:SettingsCard.Description>
                    </toolKit:SettingsCard>

                    <!-- General - Need help -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('needHelpSetting'), Mode=OneWay}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-question}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonHelpdesk'), Mode=OneWay}"
                                Click="HelpDeskButton_Click" />
                    </toolKit:SettingsCard>

                    <!-- General - Feedback -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('feedbackSetting'), Mode=OneWay}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Communication.bubble-speech}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonFeedback'), Mode=OneWay}"
                                Click="FeedbackButton_Click" />
                    </toolKit:SettingsCard>
                </StackPanel>
                <!-- Account -->
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <Grid>
                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('sidebarItemAccounts'), Mode=OneWay}"
                                   HorizontalAlignment="Left"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Subtitle}" />
                        <HyperlinkButton Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonConnectAccount'), Mode=OneWay}"
                                         HorizontalAlignment="Right"
                                         Visibility="{x:Bind ViewModel.Users.Count, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                         Click="CreateAccountButton_Click" />
                    </Grid>

                    <!-- Account - No account case -->
                    <toolKit:SettingsCard Visibility="{x:Bind ViewModel.Users.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                        <toolKit:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                                <Border CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Circle}"
                                        BorderThickness="1.2"
                                        Height="32"
                                        Width="32"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="{ThemeResource LayerOnMicaBaseAltFillColorDefault}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Users.user}"
                                                      Style="{StaticResource Infomaniak.Style.Icon.Size.S}"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center" />
                                </Border>

                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('noAccountConnected'), Mode=OneWay}"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                           VerticalAlignment="Center" />

                            </StackPanel>
                        </toolKit:SettingsCard.Header>
                        <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonConnectAccount'), Mode=OneWay}"
                                HorizontalAlignment="Right"
                                Click="CreateAccountButton_Click" />
                    </toolKit:SettingsCard>

                    <!-- Account - List -->
                    <ListView ItemsSource="{x:Bind ViewModel.Users}"
                              SelectionMode="None"
                              Visibility="{x:Bind ViewModel.Users.Count, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding"
                                        Value="0" />
                                <Setter Property="Margin"
                                        Value="{StaticResource Infomaniak.Style.Thickness.Top.XXS}" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodel:User">
                                <toolKit:SettingsExpander ItemsSource="{x:Bind AllDrives, Mode=OneWay}"
                                                          Expanded="UserSettingsExpander_Expanded">
                                    <ProgressRing Height="6"
                                                  Width="Auto"
                                                  Visibility="{x:Bind DriveRefreshInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                    <toolKit:SettingsExpander.Header>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                                            <controls:ContentLoader Height="36"
                                                                    Width="36"
                                                                    IsLoading="{x:Bind Avatar, Converter={StaticResource IsNullToBoolOrVisibilityConverter} , Mode=OneWay}"
                                                                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Circle}">
                                                <controls:ContentLoader.LoaderContent>
                                                    <PersonPicture Height="36"
                                                                   Width="36"
                                                                   HorizontalAlignment="Left"
                                                                   ProfilePicture="{x:Bind GetAvatarImageSource(36), Mode=OneWay}" />
                                                </controls:ContentLoader.LoaderContent>
                                            </controls:ContentLoader>
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}" />
                                                <TextBlock Text="{x:Bind Email, Mode=OneWay}"
                                                           Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                                                           Foreground="{ThemeResource TextFillColorSecondary}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </toolKit:SettingsExpander.Header>
                                    <toolKit:SettingsExpander.ItemTemplate>
                                        <DataTemplate x:DataType="types:IDrive">
                                            <toolKit:SettingsCard Header="{x:Bind Name, Mode=OneWay}"
                                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                                  IsClickEnabled="True"
                                                                  Click="ManageDriveButton_Click"
                                                                  Tag="{x:Bind}">
                                                <toolKit:SettingsCard.HeaderIcon>
                                                    <controls:SvgIcon Height="32"
                                                                      UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive }"
                                                                      Foreground="{x:Bind Color, Converter={StaticResource ColorToBrushConverter}}" />
                                                </toolKit:SettingsCard.HeaderIcon>
                                                <ContentControl Content="{x:Bind}"
                                                                ContentTemplateSelector="{StaticResource DriveDataTemplateSelector}" />
                                            </toolKit:SettingsCard>
                                        </DataTemplate>
                                    </toolKit:SettingsExpander.ItemTemplate>
                                    <toolKit:SettingsExpander.ItemsFooter>
                                        <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('buttonDisconnectAccount'), Mode=OneWay}"
                                                              Style="{StaticResource DefaultSettingsExpanderItemStyle}"
                                                              IsClickEnabled="True"
                                                              Click="DisconectUser_Click" />
                                    </toolKit:SettingsExpander.ItemsFooter>
                                </toolKit:SettingsExpander>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                <!-- Advanced -->
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('sidebarItemAdvanced'), Mode=OneWay}"
                               Style="{StaticResource Infomaniak.Style.TextBlock.Subtitle}" />
                    <!-- Advanced - Sync rules -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('syncRules'), Mode=OneWay}"
                                          IsClickEnabled="True"
                                          Click="SyncRulesCard_Clicked">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Edition.list-bullets}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                    </toolKit:SettingsCard>
                    <!-- Advanced - Privacy -->
                    <toolKit:SettingsExpander Header="{x:Bind kDrive:Localizer.Instance.GetString('dataManagementSettings'), Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Users.user-cog}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <!-- Presentation -->
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('dataManagementSubtitle'), Mode=OneWay}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('dataManagementDescription'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}" />
                            <!-- Matomo -->
                            <toolKit:SettingsCard Header="Matomo"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  IsClickEnabled="True"
                                                  Click="MatomoButton_Click" />
                            <!-- Sentry -->
                            <toolKit:SettingsCard Header="Sentry"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  IsClickEnabled="True"
                                                  Click="SentryButton_Click" />
                            <!-- Sources -->
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('viewSourceCode'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  IsClickEnabled="True"
                                                  Click="PrivacySeeSourcesButton_Click">
                                <toolKit:SettingsCard.ActionIcon>
                                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}"
                                                      Foreground="{ThemeResource TextFillColorPrimary}" />
                                </toolKit:SettingsCard.ActionIcon>
                            </toolKit:SettingsCard>
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>
                    <!-- Advanced - Proxy -->
                    <toolKit:SettingsExpander x:Name="ProxySettingsExpander"
                                              Header="{x:Bind kDrive:Localizer.Instance.GetString('proxySettings'), Mode=OneWay}"
                                              Description="{x:Bind kDrive:Localizer.Instance.GetString('proxyConnectionDescription'), Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Network.globe}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <ComboBox SelectedValuePath="Tag"
                                  SelectedValue="{x:Bind ViewModel.Settings.ProxyConfig.Type, Converter={StaticResource ToStringConverter}, Mode=OneWay}"
                                  SelectionChanged="ProxyTypeComboBox_Changed">
                            <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('proxyTypeHTTP'), Mode=OneWay}"
                                          Tag="HTTP" />
                            <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('proxyTypeNone'), Mode=OneWay}"
                                          Tag="None" />
                            <ComboBoxItem Content="{x:Bind kDrive:Localizer.Instance.GetString('labelSameAsSystem'), Mode=OneWay}"
                                          Tag="System" />
                        </ComboBox>
                        <toolKit:SettingsExpander.Items>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyType'), Mode=OneWay}"
                                                  IsEnabled="False">
                                <TextBox PlaceholderText="HTTP(S)"
                                         IsEnabled="False"
                                         Width="200" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyHost'), Mode=OneWay}"
                                                  IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}">
                                <TextBox x:Name="ProxyHostTextBox"
                                         PlaceholderText="0.0.0.0"
                                         TextChanged="ProxyConfig_Changed"
                                         Text="{x:Bind ViewModel.Settings.ProxyConfig.HostName, Mode=OneWay}"
                                         Width="200" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyPort'), Mode=OneWay}"
                                                  IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}">
                                <TextBox x:Name="ProxyPortTextBox"
                                         PlaceholderText="443"
                                         Text="{x:Bind ViewModel.Settings.ProxyConfig.Port, Mode=OneWay}"
                                         TextChanged="ProxyConfig_Changed"
                                         Width="200" />
                            </toolKit:SettingsCard >
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyNeedAuth'), Mode=OneWay}"
                                                  IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}">
                                <ToggleSwitch x:Name="ProxyNeedsAuthToggleSwitch"
                                              IsOn="{x:Bind ViewModel.Settings.ProxyConfig.NeedsAuth, Mode=OneWay}"
                                              Toggled="ProxyConfig_Changed" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyUser'), Mode=OneWay}"
                                                  Visibility="{x:Bind ProxyNeedsAuthToggleSwitch.IsOn, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}">
                                <TextBox x:Name="ProxyUserTextBox"
                                         PlaceholderText="John"
                                         Text="{x:Bind ViewModel.Settings.ProxyConfig.User}"
                                         TextChanged="ProxyConfig_Changed"
                                         Width="200" />
                            </toolKit:SettingsCard >
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('proxyPassword'), Mode=OneWay}"
                                                  Visibility="{x:Bind ProxyNeedsAuthToggleSwitch.IsOn, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}">
                                <PasswordBox x:Name="ProxyPwdPasswordBox"
                                             PlaceholderText="{x:Bind kDrive:Localizer.Instance.GetString('enterPasswordPlaceholder'), Mode=OneWay}"
                                             PasswordChanged="ProxyConfig_Changed"
                                             Width="200" />
                            </toolKit:SettingsCard >
                            <toolKit:SettingsCard x:Name="SaveProxySettingsCard"
                                                  Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                                    <ProgressRing x:Name="ProxySaveProgressRing"
                                                  Height="16"
                                                  Width="Auto"
                                                  Visibility="Collapsed" />
                                    <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSave'), Mode=OneWay}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}"
                                            Click="SaveProxySettingsButton_Click" />
                                    <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonCancel'), Mode=OneWay}"
                                            IsEnabled="{x:Bind ViewModel.Settings.ProxyConfig.ManualConfigrationRequired, Mode=OneWay}"
                                            Click="CancelProxySettingsButton_Click" />
                                </StackPanel>
                            </toolKit:SettingsCard >
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>
                    <!-- Advanced - Log -->
                    <toolKit:SettingsExpander x:Name="LogSettingsExpander"
                                              Header="{x:Bind kDrive:Localizer.Instance.GetString('debugLogsSettings'), Mode=OneWay}"
                                              Description="{x:Bind kDrive:Localizer.Instance.GetString('debugLogsDescription'), Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Users.users-circle-question-mark}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('enableDebugLogsSetting'), Mode=OneWay}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('enableDebugLogDescription'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}">
                                <ToggleSwitch x:Name="EnableDebugLogsToggleSwitch"
                                              IsOn="{x:Bind ViewModel.Settings.LogEnabled, Mode=OneWay}"
                                              Toggled="EnableDebugLogsToggleSwitch_Toggled" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('autoCleanupLogsSetting'), Mode=OneWay}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('autoCleanupLogsDescription'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind EnableDebugLogsToggleSwitch.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <ToggleSwitch Toggled="PurgeOldLogsToggleSwitch_Toggled"
                                              IsOn="{x:Bind ViewModel.Settings.PurgeOldLogs, Mode=OneWay}" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('extendedLogSetting'), Mode=OneWay}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('extendedLogDescription'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind EnableDebugLogsToggleSwitch.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind kDrive:Localizer.Instance.GetString('extendedLogWarning'), Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                                <ToggleSwitch x:Name="ExtendedLogToggleSwitch"
                                              Toggled="ExtendedLogToggleSwitch_Toggled"
                                              IsOn="{x:Bind ViewModel.Settings.ExtendedLogEnbaled, Mode=OneWay}" />
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('debugLevelSetting'), Mode=OneWay}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('debugLevelDescription'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind EnableDebugLogsToggleSwitch.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                                  IsEnabled="{x:Bind ExtendedLogToggleSwitch.IsOn, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}">
                                <ComboBox SelectedValue="{x:Bind ViewModel.Settings.LogLevel, Converter={StaticResource ToStringConverter}, Mode=OneWay}"
                                          SelectedValuePath="Tag"
                                          SelectionChanged="LogLevelComboBox_SelectionChanged">
                                    <ComboBoxItem Tag="Extended"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelExtended'), Mode=OneWay}" />
                                    <ComboBoxItem Tag="Debug"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelDebug'), Mode=OneWay}" />
                                    <ComboBoxItem Tag="Info"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelInfo'), Mode=OneWay}" />
                                    <ComboBoxItem Tag="Warning"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelWarning'), Mode=OneWay}" />
                                    <ComboBoxItem Tag="Error"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelError'), Mode=OneWay}" />
                                    <ComboBoxItem Tag="Fatal"
                                                  Content="{x:Bind kDrive:Localizer.Instance.GetString('logLevelFatal'), Mode=OneWay}" />
                                </ComboBox>
                            </toolKit:SettingsCard>
                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('buttonOpenDebugFolder'), Mode=OneWay}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  IsClickEnabled="True"
                                                  Click="OpenDebugFolderButton_Click"
                                                  IsActionIconVisible="False"
                                                  Visibility="{x:Bind EnableDebugLogsToggleSwitch.IsOn, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.square-arrow-diagonal-up}"
                                                  Style="{StaticResource Infomaniak.Style.Icon.Size.XS}"
                                                  Foreground="{ThemeResource TextFillColorPrimary}"
                                                  Margin="{StaticResource Infomaniak.Style.Thickness.Right.XL}" />
                            </toolKit:SettingsCard>
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>
                    <!-- Advanced - Send log -->
                    <controls:LogUploadSettingsCard LogUploadManager="{x:Bind ViewModel.Settings.LogUploadManager}" />
                    <!-- About - Privacy -->
                    <toolKit:SettingsExpander Header="{x:Bind kDrive:Localizer.Instance.GetString('aboutKDrive'), Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive-outline}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <!-- General -->
                            <toolKit:SettingsCard Header="kDrive"
                                                  Background="{ThemeResource LayerFillColorDefault}">
                                <toolKit:SettingsCard.Description>
                                    <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('aboutKDriveDescription'), Mode=OneWay}" />
                                        <controls:LicensesHyperlink DisplayedVersion="{x:Bind ViewModel.Settings.AppVersion, Mode=OneWay}" />
                                    </StackPanel>
                                </toolKit:SettingsCard.Description>
                            </toolKit:SettingsCard>
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>
                </StackPanel>

                <controls:ConsentDialog x:Name="SentryContentDialog"
                                        Description="{x:Bind kDrive:Localizer.Instance.GetString('sentryDescription'), Mode=OneWay}"
                                        LogoUriStr="{ThemeResource Infomaniak.Custom.Icons.logo-sentry}"
                                        CurrentValue="{x:Bind ViewModel.Settings.SentryEnabled, Mode=OneWay}" />
                <controls:ConsentDialog x:Name="MatomoContentDialog"
                                        Description="{x:Bind kDrive:Localizer.Instance.GetString('matomoDescription'), Mode=OneWay}"
                                        LogoUriStr="{ThemeResource Infomaniak.Custom.Icons.logo-matomo}"
                                        CurrentValue="{x:Bind ViewModel.Settings.MatomoEnabled, Mode=OneWay}" />
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>