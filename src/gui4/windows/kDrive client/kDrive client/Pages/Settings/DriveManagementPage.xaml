<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Settings.DriveManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:viewmodels="using:Infomaniak.kDrive.ViewModels"
      xmlns:settings="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />
    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />
            <!-- Drive management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Vertical"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('settingsTitle')}"
                       Style="{StaticResource Infomaniak.Style.TextBlock.Title}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>

        <!-- Drive management -->
        <ScrollView Grid.Row="1">
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <StackPanel Orientation="Horizontal"
                            Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                    <controls:SvgIcon Height="20"
                                      UriString="{StaticResource Infomaniak.DS.Icons.Products.kDrive}"
                                      Foreground="{x:Bind BaseDrive.Color, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" />
                    <TextBlock Text="{x:Bind BaseDrive.Name, Mode=OneWay}"
                               Style="{StaticResource BodyLargeTextBlockStyle}" />
                </StackPanel>

                <!-- Main sync is setted -->
                <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                            Visibility="{x:Bind ManagedDrive.MainSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay, FallbackValue='Collapsed'}">

                    <!-- Location -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('labelSyncLocation')}">
                        <toolKit:SettingsCard.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-open}"
                                              Height="20"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </toolKit:SettingsCard.HeaderIcon>
                        <HyperlinkButton Content="{x:Bind ManagedDrive.MainSync.LocalPath, Mode=OneWay}"
                                         Click="LocationHyperLinkButton_Clicked" />
                    </toolKit:SettingsCard>

                    <!-- Folder Selection -->
                    <toolKit:SettingsExpander Header="{x:Bind kDrive:Localizer.Instance.GetString('labelSynchronisation')}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-loop}"
                                              Height="32"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <toolKit:SettingsCard HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch"
                                                  ContentAlignment="Vertical">
                                <!-- Presentation -->
                                <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="{x:Bind kDrive:Localizer.Instance.GetString('selectFoldersToSync')}"
                                               TextWrapping="Wrap" />
                                    
                                    <controls:SyncExclusionSelector Grid.Row="1"
                                                                    Sync="{x:Bind ManagedDrive.MainSync, Mode=OneWay}"
                                                                    CanShowSaveMenu="True"
                                                                    HorizontalAlignment="Stretch" />
                                </Grid>
                            </toolKit:SettingsCard>
                        </toolKit:SettingsExpander.Items>
                    </toolKit:SettingsExpander>

                    <!-- Lite Sync -->
                    <toolKit:SettingsExpander x:Name="SyncTypeExpander"
                                              Header="{x:Bind kDrive:Localizer.Instance.GetString('fileSyncModeDescription')}"
                                              Visibility="{x:Bind ManagedDrive.MainSync.SupportOnlineMode, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <toolKit:SettingsExpander.HeaderIcon>
                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Essentials.cog}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                              Height="32" />
                        </toolKit:SettingsExpander.HeaderIcon>
                        <toolKit:SettingsExpander.Items>
                            <toolKit:SettingsCard Background="{ThemeResource LayerFillColorDefault}"
                                                  ContentAlignment="Left"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="10000" />
                                        <!-- Make the entire card clickable to select the radio button -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Card content -->
                                    <toolKit:SettingsCard Grid.Column="1"
                                                          Header="{x:Bind kDrive:Localizer.Instance.GetString('storedOnline')}"
                                                          Description="{x:Bind kDrive:Localizer.Instance.GetString('storedOnlineDescription')}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0" />

                                    <!-- RadioButton -->
                                    <RadioButton x:Name="OnlineRadioButton"
                                                 Grid.ColumnSpan="2"
                                                 GroupName="SyncModeRadioGroup"
                                                 MinWidth="0"
                                                 HorizontalAlignment="Stretch"
                                                 IsChecked="{x:Bind ManagedDrive.MainSync.IsTypeOnline, Mode=OneWay}"
                                                 IsEnabled="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                                 Click="SyncTypeRadioButton_Click" />
                                </Grid>
                            </toolKit:SettingsCard>

                            <toolKit:SettingsCard Background="{ThemeResource LayerFillColorDefault}"
                                                  ContentAlignment="Left"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="10000" />
                                        <!-- Make the entire card clickable to select the radio button -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Card content -->
                                    <toolKit:SettingsCard Grid.Column="1"
                                                          Header="{x:Bind kDrive:Localizer.Instance.GetString('availableOffline')}"
                                                          Description="{x:Bind kDrive:Localizer.Instance.GetString('availableOfflineDescription')}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="0" />

                                    <!-- RadioButton -->
                                    <RadioButton x:Name="OfflineRadioButton"
                                                 Grid.ColumnSpan="2"
                                                 GroupName="SyncModeRadioGroup"
                                                 MinWidth="0"
                                                 IsChecked="{x:Bind ManagedDrive.MainSync.IsTypeOnline, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                                 IsEnabled="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                                 HorizontalAlignment="Stretch"
                                                 Click="SyncTypeRadioButton_Click" />
                                </Grid>
                            </toolKit:SettingsCard>

                            <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('applyingChange')}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('syncModeApplying')}"
                                                  Background="{ThemeResource LayerFillColorDefault}"
                                                  Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            </toolKit:SettingsCard>

                        </toolKit:SettingsExpander.Items>
                        <ProgressRing IsActive="True"
                                      Height="16"
                                      Width="16"
                                      Visibility="{x:Bind ManagedDrive.MainSync.SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                    </toolKit:SettingsExpander>

                    <!-- Remove sync -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('buttonRemoveSync')}"
                                          IsClickEnabled="True"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                          PointerExited="FixForegroundOnPointerExited"
                                          Click="RemoveSyncSettingsCard_Click">
                    </toolKit:SettingsCard>
                </StackPanel>

                <!-- Main sync is not setted -->
                <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('synchronizationSettings')}"
                                      Visibility="{x:Bind ManagedDrive.MainSync, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, Mode=OneWay}"
                                      IsClickEnabled="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
                        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('notSyncedDrive')}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                                   Foreground="{ThemeResource TextFillColorSecondary}" />

                        <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonEnable')}"
                                Click="SetupMainSyncButton_Click" />
                    </StackPanel>
                    <toolKit:SettingsCard.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Arrows.arrow-loop}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </toolKit:SettingsCard.HeaderIcon>
                </toolKit:SettingsCard>

                <!-- Advanced syncs -->
                <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('advancedSyncTitle')}"
                                      IsClickEnabled="True"
                                      Click="AdvancedSyncsSettingsCard_Click">
                    <toolKit:SettingsCard.HeaderIcon>
                        <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-connect}"
                                          Height="32"
                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </toolKit:SettingsCard.HeaderIcon>
                </toolKit:SettingsCard>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
