<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Settings.DriveAdvancedSyncsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      xmlns:viewmodel="using:Infomaniak.kDrive.ViewModels"
      mc:Ignorable="d">
    <Page.Resources>
        <!-- Converters -->
        <converters:StringPathToFileNameConverter x:Key="StringPathToFileNameConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Data template -->
        <DataTemplate x:Key="AdvancedSyncItemTemplate"
                      x:DataType="viewmodel:Sync">
            <toolKit:SettingsExpander Header="{x:Bind LocalPath, Converter={StaticResource StringPathToFileNameConverter}}">
                <toolKit:SettingsExpander.HeaderIcon>
                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder}"
                                      Height="32" />
                </toolKit:SettingsExpander.HeaderIcon>
                <toolKit:SettingsExpander.Items>
                    <toolKit:SettingsCard x:Uid="Page_DriveAdvancedSyncsPage_LocalFolder">
                        <HyperlinkButton Content="{x:Bind LocalPath}"
                                         Click="LocalPathLink_Click" />
                    </toolKit:SettingsCard>
                    <toolKit:SettingsCard x:Uid="Page_DriveAdvancedSyncsPage_RemoteFolder">
                        <HyperlinkButton Content="{x:Bind RemotePath}"
                                         Click="RemotePathLink_Click" />
                    </toolKit:SettingsCard>

                    <!-- Lite sync -->

                    <toolKit:SettingsCard x:Uid="Page_Settings_DriveManagementPage_SyncMode_InProgress"
                                          Visibility="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    </toolKit:SettingsCard>

                    <toolKit:SettingsCard ContentAlignment="Left"
                                          Visibility="{x:Bind SupportOnlineMode, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <Grid HorizontalAlignment="Stretch"
                              Visibility="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="10000" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2">
                                <TextBlock x:Uid="Page_DriveAdvancedSyncsPage_SyncModeHeader" />
                                <TextBlock x:Uid="Page_DriveAdvancedSyncsPage_SyncModeCaption"
                                           Style="{StaticResource CaptionTextBlockStyle}" />

                            </StackPanel>
                            <!-- Card content -->
                            <toolKit:SettingsCard Grid.Row="1"
                                                  Grid.Column="1"
                                                  x:Uid="Page_Settings_DriveManagementPage_SyncMode_Online"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="0" />

                            <!-- RadioButton -->
                            <RadioButton x:Name="OnlineRadioButton"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         GroupName="{x:Bind LocalPath}"
                                         MinWidth="0"
                                         HorizontalAlignment="Stretch"
                                         IsChecked="{x:Bind IsTypeOnline, Mode=OneWay}"
                                         Click="SyncTypeRadioButton_Click"
                                         IsEnabled="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}" />

                            <!-- Card content -->
                            <toolKit:SettingsCard Grid.Column="1"
                                                  Grid.Row="2"
                                                  x:Uid="Page_Settings_DriveManagementPage_SyncMode_Offline"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="0" />

                            <!-- RadioButton -->
                            <RadioButton x:Name="OfflineRadioButton"
                                         Grid.ColumnSpan="2"
                                         Grid.Row="2"
                                         GroupName="{x:Bind LocalPath}"
                                         MinWidth="0"
                                         HorizontalAlignment="Stretch"
                                         IsChecked="{x:Bind IsTypeOnline, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                         Click="SyncTypeRadioButton_Click"
                                         IsEnabled="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}" />
                        </Grid>
                    </toolKit:SettingsCard>

                    <!--- Folder selection -->
                    <toolKit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          ContentAlignment="Vertical">
                        <!-- Presentation -->
                        <Grid RowSpacing="{StaticResource Infomaniak.Style.Spacing.M}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0"
                                        Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}">
                                <TextBlock x:Uid="Page_Settings_DriveManagementPage_FolderSelection_Presentation_Header"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Body}"
                                           TextWrapping="Wrap" />

                                <TextBlock x:Uid="Page_Settings_DriveManagementPage_FolderSelection_Presentation_Description"
                                           Style="{StaticResource Infomaniak.Style.TextBlock.Caption}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:SyncExclusionSelector Grid.Row="1"
                                                            Sync="{x:Bind Mode=OneWay}"
                                                            CanShowSaveMenu="True"
                                                            HorizontalAlignment="Stretch" />
                        </Grid>
                    </toolKit:SettingsCard>
                    <toolKit:SettingsCard x:Uid="Page_DriveAdvancedSyncsPage_RemoveSyncButton"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                          PointerExited="FixForegroundOnPointerExited"
                                          IsClickEnabled="True"
                                          Click="RemoveSyncButton_Click" />
                </toolKit:SettingsExpander.Items>
            </toolKit:SettingsExpander>
        </DataTemplate>

    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />

            <!-- Advanced syncs management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
            <TextBlock x:Uid="Page_SettingsPage_Title"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>
        <ScrollView Grid.Row="1">

            <!-- Drive management -->
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">
                <StackPanel>
                    <!-- Subtitle -->
                    <TextBlock x:Uid="Page_DriveAdvancedSyncsPage_Title"
                               Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                               Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}" />

                    <TextBlock x:Uid="Page_DriveAdvancedSyncsPage_Subtitle"
                               Style="{StaticResource BodyTextBlockStyle}" />
                    <TextBlock x:Uid="Page_DriveAdvancedSyncsPage_Subtitle_Caption"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ListView ItemsSource="{x:Bind ManagedDrive.AdvancedSyncs, Mode=OneWay}"
                          ItemTemplate="{StaticResource AdvancedSyncItemTemplate}"
                          VerticalContentAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="Margin"
                                    Value="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <Button x:Uid="Page_DriveAdvancedSyncsPage_AddSyncButton" />
                <!-- TODO: Bind the button logic once the UI/UX is ready -->
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
