<Page x:Class="Infomaniak.kDrive.Pages.Settings.DriveAdvancedSyncsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.Pages.Settings"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      xmlns:toolKit="using:CommunityToolkit.WinUI.Controls"
      xmlns:viewmodel="using:Infomaniak.kDrive.ViewModels"
      xmlns:kDrive="using:Infomaniak.kDrive"
      mc:Ignorable="d">
    <Page.Resources>
        <!-- Converters -->
        <converters:StringPathToFileNameConverter x:Key="StringPathToFileNameConverter" />
        <converters:BooleanToInvertedBooleanConverter x:Key="BooleanToInvertedBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IsNullToBoolOrVisibilityConverter x:Key="IsNullToBoolOrVisibilityConverter" />

        <!-- Data template -->
        <DataTemplate x:Key="AdvancedSyncItemTemplate"
                      x:DataType="viewmodel:Sync">
            <toolKit:SettingsExpander Header="{x:Bind LocalPath, Converter={StaticResource StringPathToFileNameConverter}}">
                <toolKit:SettingsExpander.HeaderIcon>
                    <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Documents.folder-outline}"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                      Height="32" />
                </toolKit:SettingsExpander.HeaderIcon>
                <toolKit:SettingsExpander.Items>
                    <!-- Local path -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('localLocation')}">
                        <HyperlinkButton Content="{x:Bind LocalPath}"
                                         Click="LocalPathLink_Click" />
                    </toolKit:SettingsCard>

                    <!-- Remote path -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('remoteLocation')}">
                        <HyperlinkButton Content="{x:Bind RemotePath, Converter={StaticResource StringPathToFileNameConverter}}"
                                         Click="RemotePathLink_Click">
                            <ToolTipService.ToolTip>
                                <TextBlock Text="{x:Bind RemotePath}" />
                            </ToolTipService.ToolTip>
                        </HyperlinkButton>
                    </toolKit:SettingsCard>

                    <!--- Folder selection -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('labelSyncedFolders')}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}">

                            <controls:ContentLoader IsLoading="{x:Bind HasExcludedFolder, Converter={StaticResource IsNullToBoolOrVisibilityConverter}, Mode=OneWay}"
                                                    CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.Uniform.S}"
                                                    LoaderMinHeight="12"
                                                    Height="24"
                                                    LoaderMinWidth="120">
                                <controls:ContentLoader.LoaderContent>
                                    <Grid>
                                        <!-- No exclusion -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{x:Bind HasExcludedFolder, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}"
                                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                                                    VerticalAlignment="Center">
                                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Actions.circle-check-outline}"
                                                              Style="{StaticResource Infomaniak.Style.Icon.Size.XS}"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('labelAllFolders')}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{x:Bind HasExcludedFolder, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                                    Spacing="{StaticResource Infomaniak.Style.Spacing.XXS}"
                                                    VerticalAlignment="Center">

                                            <controls:SvgIcon UriString="{StaticResource Infomaniak.DS.Icons.Edition.pencil}"
                                                              Style="{StaticResource Infomaniak.Style.Icon.Size.XS}"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('onboardingExclusionSummarySome')}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </controls:ContentLoader.LoaderContent>
                            </controls:ContentLoader>
                            <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonSelect')}"
                                    Click="SyncExclusionButton_Click" />
                        </StackPanel>
                    </toolKit:SettingsCard>

                    <!-- Lite sync -->
                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('applyingChange')}"
                                          Description="{x:Bind kDrive:Localizer.Instance.GetString('syncModeApplying')}"
                                          Visibility="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    </toolKit:SettingsCard>

                    <toolKit:SettingsCard ContentAlignment="Left"
                                          Visibility="{x:Bind SupportOnlineMode, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                        <Grid HorizontalAlignment="Stretch"
                              Visibility="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter='Inverted=True', Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="10000" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2">
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('fileSyncMode')}" />
                                <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('fileSyncModeDescription')}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />

                            </StackPanel>
                            <!-- Card content -->
                            <toolKit:SettingsCard Grid.Row="1"
                                                  Grid.Column="1"
                                                  Header="{x:Bind kDrive:Localizer.Instance.GetString('storedOnline')}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('storedOnlineDescription')}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="0" />

                            <!-- RadioButton -->
                            <RadioButton x:Name="OnlineRadioButton"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         GroupName="{x:Bind LocalPath}"
                                         MinWidth="0"
                                         HorizontalAlignment="Stretch"
                                         IsChecked="{x:Bind IsTypeOnline, Mode=OneWay}"
                                         Click="SyncTypeRadioButton_Click"
                                         IsEnabled="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}" />

                            <!-- Card content -->
                            <toolKit:SettingsCard Grid.Column="1"
                                                  Grid.Row="2"
                                                  Header="{x:Bind kDrive:Localizer.Instance.GetString('availableOffline')}"
                                                  Description="{x:Bind kDrive:Localizer.Instance.GetString('availableOfflineDescription')}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="0" />

                            <!-- RadioButton -->
                            <RadioButton x:Name="OfflineRadioButton"
                                         Grid.ColumnSpan="2"
                                         Grid.Row="2"
                                         GroupName="{x:Bind LocalPath}"
                                         MinWidth="0"
                                         HorizontalAlignment="Stretch"
                                         IsChecked="{x:Bind IsTypeOnline, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}"
                                         Click="SyncTypeRadioButton_Click"
                                         IsEnabled="{x:Bind SyncTypeMigrationInProgress, Converter={StaticResource BooleanToInvertedBooleanConverter}, Mode=OneWay}" />
                        </Grid>
                    </toolKit:SettingsCard>

                    <toolKit:SettingsCard Header="{x:Bind kDrive:Localizer.Instance.GetString('buttonRemoveSync')}"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                          PointerExited="FixForegroundOnPointerExited"
                                          IsClickEnabled="True"
                                          Click="RemoveSyncButton_Click" />
                </toolKit:SettingsExpander.Items>
            </toolKit:SettingsExpander>
        </DataTemplate>

    </Page.Resources>
    <Grid Padding="{StaticResource Infomaniak.Style.Thickness.Sides.Vertical.L}"
          RowSpacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <Grid.RowDefinitions>
            <!-- Title & BreadCrumb bar -->
            <RowDefinition Height="Auto" />

            <!-- Advanced syncs management -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title & BreadCrumb bar -->
        <StackPanel Grid.Row="0"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                    Margin="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.L}">
            <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('settingsTitle')}"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <BreadcrumbBar x:Name="NavBar"
                           ItemClicked="NavBar_ItemClicked" />
        </StackPanel>
        <ScrollView Grid.Row="1">

            <!-- Drive management -->
            <StackPanel Spacing="{StaticResource Infomaniak.Style.Spacing.XS}"
                        Margin="{StaticResource Infomaniak.Style.Thickness.Sides.Horizontal.L}">
                <StackPanel>
                    <!-- Subtitle -->
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('advancedSyncTitle')}"
                               Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                               Margin="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}" />

                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('advancedSyncSubtitle')}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                    <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('advancedSyncDescription')}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ListView ItemsSource="{x:Bind ManagedDrive.AdvancedSyncs, Mode=OneWay}"
                          ItemTemplate="{StaticResource AdvancedSyncItemTemplate}"
                          VerticalContentAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="Margin"
                                    Value="{StaticResource Infomaniak.Style.Thickness.Bottom.XS}" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <Button Content="{x:Bind kDrive:Localizer.Instance.GetString('buttonAddAdvancedSync')}"
                        Click="AddAdvancedSyncButton_Click" />
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
