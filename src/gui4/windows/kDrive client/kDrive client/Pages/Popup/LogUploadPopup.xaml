<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Popup.LogUploadPopup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="using:Infomaniak.kDrive.Localizer">

    <StackPanel VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <TextBlock Text="{x:Bind loc:Localizer.Instance.GetString('largeFolderRecommendation')}"
                   TextWrapping="WrapWholeWords" />
        <CheckBox x:Name="CheckBox"
                  Content="{x:Bind loc:Localizer.Instance.GetString('sendLastSessionOnly')}"
                  IsChecked="False" />
    </StackPanel>
</Page>
