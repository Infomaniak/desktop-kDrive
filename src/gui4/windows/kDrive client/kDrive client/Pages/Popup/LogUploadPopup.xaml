<Page x:Class="Infomaniak.kDrive.Pages.Popup.LogUploadPopup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:kDrive="using:Infomaniak.kDrive">

    <StackPanel VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
        <TextBlock Text="{x:Bind kDrive:Localizer.Instance.GetString('largeFolderRecommendation')}"
                   TextWrapping="WrapWholeWords" />
        <CheckBox x:Name="CheckBox"
                  Content="{x:Bind kDrive:Localizer.Instance.GetString('sendLastSessionOnly')}"
                  IsChecked="False" />
    </StackPanel>
</Page>
