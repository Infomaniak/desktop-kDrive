<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Infomaniak.kDrive.Pages.Popup.AddExclusionRulePopup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource Infomaniak.Style.Spacing.L}">
        <StackPanel VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    Spacing="{StaticResource Infomaniak.Style.Spacing.S}">
            <TextBlock x:Uid="Pages_AddExclusionRulePopup_Title"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock x:Uid="Pages_AddExclusionRulePopup_Description"
                       TextWrapping="WrapWholeWords"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <TextBox x:Uid="Pages_AddExclusionRulePopup_TextBox"
                 x:Name="TextBox" />
        <CheckBox x:Name="CheckBox"
                  x:Uid="Pages_AddExclusionRulePopup_CheckBox"
                  IsChecked="False" />
    </StackPanel>
</Page>
