<local:SpecialErroBasePage x:Class="Infomaniak.kDrive.Pages.DriveAccessDeniedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Infomaniak.kDrive.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:Infomaniak.kDrive.CustomControls"
      xmlns:converters="using:Infomaniak.kDrive.Converters"
      mc:Ignorable="d">
    <local:SpecialErroBasePage.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </local:SpecialErroBasePage.Resources>
    <Border Background="{ThemeResource LayerFillColorDefault}"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefault}"
            Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.L}"
            CornerRadius="{StaticResource Infomaniak.Style.CornerRadius.S}">

        <RelativePanel HorizontalAlignment="Center"
                       VerticalAlignment="Center">
            <StackPanel x:Name="ContentPanel"
                        RelativePanel.AlignVerticalCenterWithPanel="True"
                        RelativePanel.AlignHorizontalCenterWithPanel="True"
                        Spacing="{StaticResource Infomaniak.Style.Spacing.M}">

                <TextBlock x:Uid="Page_DriveAccessDeniedPage_Title"
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />

                <TextBlock x:Uid="Page_DriveAccessDeniedPage_Subtitle"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />

                <Button x:Uid="Page_DriveAccessDeniedPage_Button"
                        HorizontalAlignment="Center"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="RetryButton_Click" />
            </StackPanel>

            <!-- Status indicator above the content -->
            <controls:DriveStatusIndicator Drive="{x:Bind ViewModel.SelectedSync.Drive, Mode=OneWay}"
                                           IconUri="{StaticResource Infomaniak.DS.Icons.Actions.triangle-alert-outline}"
                                           IconForegroundBrush="{ThemeResource SystemFillColorCautionBrush}"
                                           IconBackgroundBrush="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                           RelativePanel.Above="ContentPanel"
                                           RelativePanel.AlignHorizontalCenterWith="ContentPanel"
                                           Margin="{StaticResource Infomaniak.Style.Thickness.Uniform.XXL}" />

        </RelativePanel>

    </Border>

</local:SpecialErroBasePage>
