<Project Sdk="WixToolset.Sdk/6.0.2">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <DefineConstants>desktop-kDriveDir=$(SolutionDir)..\..\..</DefineConstants>
    <VerboseOutput>true</VerboseOutput>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <SuppressIces>ICE57;ICE61</SuppressIces>
  </PropertyGroup>
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <WixOutputName Condition=" '$(WixOutputName)'=='' ">$(OutputName)</WixOutputName>
    <UserSecretsId>3821c68b-8a2a-49a7-8e78-f7810232e10d</UserSecretsId>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="WixToolset.BootstrapperApplications.wixext" Version="6.0.2" />
    <PackageReference Include="WixToolset.Util.wixext" Version="6.0.2" />
  </ItemGroup>
</Project>